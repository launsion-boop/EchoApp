  "setup": {
    "app_mode": "standalone",
    "services": [],
    "config_fields": [],
    "share_profile": {
      "strip_on_share": [],
      "include_defaults": true
    },
    "install_contract": {
      "requires_network": true,
      "requires_auth": false,
      "requires_database": false,
      "requires_notification": false
    }
  },
  "session": {
    "original_intent": "输入 URL，把网页上的图片/PDF/音频/视频等文件列出来，可下载。",
    "features": [
      {
        "id": "url-input",
        "name": "URL 输入 + 解析按钮",
        "rationale": "单输入入口，回车即触发，降低操作门槛。"
      },
      {
        "id": "bridge-fetch",
        "name": "bridge fetch 绕 CORS",
        "rationale": "浏览器跨域抓页面 HTML 会被 CORS 拦；通过 echoclaw.invoke('fetch') 走 Desktop 主进程，无 CORS 约束。"
      },
      {
        "id": "resource-classify",
        "name": "按类型分 7 tab",
        "rationale": "全部 / 图片 / 视频 / 音频 / PDF / 文档 / 链接 — 比单一长列表更易扫读。"
      },
      {
        "id": "image-thumbnail",
        "name": "图片缩略图",
        "rationale": "image 卡片直接显示原图 lazy+async 加载，referrerPolicy=no-referrer 避免防盗链 referer 被拦。"
      },
      {
        "id": "download-native",
        "name": "下载走 <a download>",
        "rationale": "避开 fs.save bridge 的不确定性。跨域资源浏览器会在新 tab 打开让用户 Cmd+S 手动保存。"
      },
      {
        "id": "broad-extraction",
        "name": "扩展提取维度",
        "rationale": "不只 img/video/audio src，还抓 srcset / picture source / meta og:image / favicon / iframe 嵌入（YouTube/Bilibili/PDF） / inline style background-image / a[href] 按 ext 分类。"
      }
    ],
    "decisions": [
      {
        "point": "跨域抓 HTML 的技术路径",
        "choice": "bridge fetch primary + 浏览器 fetch fallback（仅 CORS 友好站点能成功）",
        "rationale": "bridge 是唯一可靠的跨域抓取方式"
      },
      {
        "point": "下载用 bridge 还是 <a download>",
        "choice": "<a download target=_blank>",
        "rationale": "避免 fs.save 或 bridge fetch binary body 的编码不确定性；浏览器对跨域资源的行为是新 tab 打开，UX 稍差但可靠。后续可加 bridge fetch binary 版做'静默下载'作为升级。"
      },
      {
        "point": "是否做「全部下载 ZIP」",
        "choice": "v0.1 不做",
        "rationale": "需要 bridge fetch 每个资源的 binary body，不确定当前 bridge 对 binary 返回的处理；v0.2 再加。"
      }
    ],
    "design_rationale": {
      "visual": "跟 miniclaw-browser 统一主题 — 紫+青渐变 accent、圆角卡片、深色优先、--ec-* 变量自适应主题。",
      "density": "卡片 min-width 200px 网格自适应。图片 aspect-ratio 4:3 统一缩略尺寸。",
      "motion": "hover translateY + 紫色光晕。toast 底部弹出 220ms 渐显。"
    },
    "state_schema": {
      "url": "string — 当前解析的 URL",
      "loading": "boolean — 抓取中",
      "error": "string — 错误消息（空 = 无错）",
      "filter": "string — 当前 tab (all|image|video|audio|pdf|doc|link)",
      "resources": "array<{url, kind, name, ...}> — 解析结果",
      "sourceUrl": "string — 本次成功解析的源 URL",
      "sourceTitle": "string — 页面 <title>"
    },
    "created": "2026-04-22T11:00:00Z"
  },
