{"manifest":{"id":"echorec","name":{"en":"EchoREC","zh-CN":"EchoREC"},"version":"0.1.28","color":"#E94F37","icon_svg":"<rect x=\"9\" y=\"3\" width=\"6\" height=\"12\" rx=\"3\" fill=\"currentColor\"/><path d=\"M5 11a7 7 0 0 0 14 0\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" fill=\"none\"/><line x1=\"12\" y1=\"18\" x2=\"12\" y2=\"21\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/><line x1=\"8\" y1=\"21\" x2=\"16\" y2=\"21\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>","description":{"en":"Real-time meeting transcription with speaker diarization, rolling summaries, and research task dispatch","zh-CN":"实时会议转写（含说话人识别）+ 滚动总结 + 研究任务派发"},"capabilities":["ui","storage","network","database","audio","microphone","echoagent_invoke","filesystem"],"network_allow":["wss://coding.echoclaw.me"],"db_version":3,"update_source":{"type":"github","repo":"launsion-boop/EchoApp","app_path":"apps/echorec/app.json"}},"html":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>EchoREC</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml,body{height:100%;background:#f6f7f8;color:#181b1f;font:13px/1.5 var(--ec-font-family);overflow:hidden}\nbutton{font:inherit;color:inherit;background:none;border:none;cursor:pointer}\nbutton:disabled{cursor:not-allowed;opacity:.45}\ninput,textarea{font:inherit;color:inherit;background:#fff;border:1px solid #dfe3e8;border-radius:12px;padding:8px 11px;outline:none}\ninput:focus,textarea:focus{border-color:#E94F37;box-shadow:0 0 0 3px rgba(233,79,55,.12)}\n::-webkit-scrollbar{width:8px;height:8px}\n::-webkit-scrollbar-thumb{background:#cfd5dc;border-radius:10px;border:2px solid transparent;background-clip:padding-box}\n::-webkit-scrollbar-thumb:hover{background:#aeb7c2;border:2px solid transparent;background-clip:padding-box}\n\n.app{display:grid;grid-template-columns:280px minmax(520px,1fr) 320px;height:100vh;background:#f6f7f8}\n\nbody.home-mode .app{grid-template-columns:1fr}\nbody.home-mode .sidebar,body.home-mode .topbar,body.home-mode .panels,body.home-mode .tasks{display:none}\nbody.home-mode .main{overflow:auto;background:#f6f7f8}\n.home-screen{display:none;min-height:100vh;padding:34px clamp(24px,5vw,72px) 44px;overflow-y:auto;background:#f6f7f8}\nbody.home-mode .home-screen{display:block}\n.home-shell{max-width:1120px;margin:0 auto;display:grid;gap:24px}\n.home-hero{background:#fff;border:1px solid #e3e7ec;border-radius:28px;padding:34px;box-shadow:0 18px 48px rgba(22,29,37,.07);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:28px;align-items:center}\n.home-kicker{font-size:12px;font-weight:700;color:#E94F37;margin-bottom:10px;letter-spacing:0;text-transform:none}\n.home-title{font-size:34px;line-height:1.18;font-weight:760;color:#14171b;letter-spacing:0;margin:0 0 12px}\n.home-subtitle{max-width:620px;font-size:15px;line-height:1.8;color:#59636f;margin:0}\n.home-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:24px}.home-primary,.home-secondary{height:42px;padding:0 16px;border-radius:14px;font-size:13px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;white-space:nowrap}.home-primary{background:#E94F37;color:#fff;box-shadow:0 10px 24px rgba(233,79,55,.23)}.home-primary:hover{background:#d9432d}.home-secondary{background:#fff;border:1px solid #dfe4ea;color:#303741}.home-secondary:hover{background:#f0f3f6}\n.home-meter{min-width:188px;padding:18px;border-radius:22px;background:#fbfcfd;border:1px solid #eef1f4;display:grid;gap:8px}.home-meter-label{font-size:12px;color:#707882}.home-meter-value{font-size:24px;font-weight:760;color:#14171b;font-variant-numeric:tabular-nums}.home-meter-note{font-size:12px;color:#88919c;line-height:1.5}\n.home-history{background:#fff;border:1px solid #e3e7ec;border-radius:24px;box-shadow:0 12px 36px rgba(22,29,37,.05);overflow:hidden}.home-history-head{padding:20px 22px;border-bottom:1px solid #eef1f4;display:flex;align-items:center;justify-content:space-between;gap:12px}.home-history-title{font-size:17px;font-weight:760;color:#14171b}.home-history-count{font-size:12px;color:#707882}.home-session-list{padding:10px}.home-session-card{width:100%;text-align:left;padding:14px 14px;border-radius:16px;display:grid;grid-template-columns:minmax(0,1fr) auto;gap:12px;align-items:center;border:1px solid transparent;background:#fff;transition:background .16s ease,border-color .16s ease,box-shadow .16s ease}.home-session-card:hover{background:#fbfcfd;border-color:#e4e8ee;box-shadow:0 6px 18px rgba(16,24,40,.06)}.home-session-name{font-size:14px;font-weight:700;color:#20262d;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.home-session-meta{margin-top:5px;font-size:12px;color:#737c86;display:flex;gap:8px;flex-wrap:wrap}.home-session-open{font-size:12px;color:#E94F37;font-weight:700;white-space:nowrap}.home-empty{padding:34px 18px;text-align:center;color:#8a939e;font-size:13px;line-height:1.7}\n@media (max-width:860px){.home-screen{padding:18px}.home-hero{grid-template-columns:1fr;padding:24px}.home-title{font-size:27px}.home-meter{min-width:0}.home-session-card{grid-template-columns:1fr}.home-session-open{display:none}}\n\n/* Library */\n.sidebar{background:#fbfbfc;border-right:1px solid #e2e5e9;display:flex;flex-direction:column;min-width:0}\n.brand{height:64px;padding:0 18px;border-bottom:1px solid #e7eaee;display:flex;align-items:center;gap:10px}\n.brand-logo{width:30px;height:30px;border-radius:9px;background:#E94F37;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:#fff;box-shadow:0 8px 18px rgba(233,79,55,.22)}\n.brand-name{font-weight:700;font-size:15px;letter-spacing:.01em;color:#111418}\n.sidebar-hd{padding:16px 16px 8px;font-size:11px;color:#707882;text-transform:uppercase;letter-spacing:.08em;display:flex;justify-content:space-between;align-items:center}\n.sidebar-hd button{width:28px;height:28px;border-radius:10px;background:#fff;border:1px solid #e1e5ea;color:#2c3238;font-size:18px;line-height:1;box-shadow:0 1px 2px rgba(16,24,40,.04)}\n.sidebar-hd button:hover{background:#f0f3f6}\n.session-list{flex:1;overflow-y:auto;padding:0 10px 14px}\n.session-item{padding:12px 12px;border-radius:16px;margin:6px 0;cursor:pointer;display:flex;flex-direction:column;gap:7px;border:1px solid transparent;background:transparent;transition:background .16s ease,border-color .16s ease,box-shadow .16s ease,transform .16s ease}\n.session-item:hover{background:#fff;border-color:#e4e8ee;box-shadow:0 4px 14px rgba(16,24,40,.06)}\n.session-item.active{background:#fff;border-color:#f0c9c1;box-shadow:0 10px 28px rgba(31,38,46,.08)}\n.session-title-row{display:flex;align-items:center;gap:8px;min-width:0}\n.session-title{font-size:13px;font-weight:650;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#1f242b;flex:1;min-width:0}\n.session-delete{width:24px;height:24px;border-radius:8px;color:#98a2ad;display:flex;align-items:center;justify-content:center;opacity:0;flex:0 0 24px;font-size:16px;line-height:1}\n.session-item:hover .session-delete{opacity:1}\n.session-delete:hover{background:#fff5f2;color:#d92d20}\n.session-meta{font-size:11px;color:#737c86;display:flex;align-items:center;gap:6px;flex-wrap:wrap}\n\n/* Workspace */\n.main{display:flex;flex-direction:column;min-width:0;min-height:0;overflow:hidden;background:#f6f7f8}\n.topbar{height:72px;padding:0 24px;display:flex;align-items:center;gap:14px;border-bottom:1px solid #e2e5e9;background:rgba(246,247,248,.92);backdrop-filter:blur(18px);position:relative;z-index:2}\n.mic-btn{width:46px;height:46px;border-radius:50%;background:#E94F37;display:flex;align-items:center;justify-content:center;color:#fff;box-shadow:0 10px 24px rgba(233,79,55,.25);transition:transform .16s ease,box-shadow .16s ease,background .16s ease}\n.mic-btn:hover{transform:translateY(-1px);box-shadow:0 14px 30px rgba(233,79,55,.28)}\n.mic-btn.recording{animation:pulse 1.7s infinite;background:#e84028}\n@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(233,79,55,.42)}70%{box-shadow:0 0 0 15px rgba(233,79,55,0)}100%{box-shadow:0 0 0 0 rgba(233,79,55,0)}}\n.mic-btn svg{width:18px;height:18px}\n.mic-btn .ic-pause{display:none}\n.mic-btn.recording .ic-mic{display:none}\n.mic-btn.recording .ic-pause{display:block}\n.stop-btn{width:48px;height:48px;flex:0 0 48px;border-radius:50%;background:#fff;border:1px solid #dce1e7;display:flex;align-items:center;justify-content:center;color:#111418;transition:background .16s ease,border-color .16s ease,transform .16s ease;box-shadow:0 4px 14px rgba(16,24,40,.08);position:relative;z-index:5;pointer-events:auto}\n.stop-btn:hover{background:#f0f3f6;border-color:#ccd4dd;transform:translateY(-1px)}\n.stop-btn svg{width:15px;height:15px}\n.status{flex:1;display:flex;align-items:center;gap:9px;color:#59636f;font-size:13px;min-width:0}\n.dot{width:8px;height:8px;border-radius:50%;background:#a8b0ba;flex:0 0 auto}\n.dot.connected{background:#16a064}.dot.error{background:#d92d20}.dot.recording{background:#E94F37;animation:blink 1s infinite}@keyframes blink{50%{opacity:.35}}\n.timer{font-variant-numeric:tabular-nums;color:#303741;font-size:14px;font-weight:650;letter-spacing:.02em}\n.quota{font-variant-numeric:tabular-nums;color:#59636f;font-size:12px;padding:7px 10px;border-radius:12px;border:1px solid #dfe4ea;background:#fff;white-space:nowrap}\n.quota.quota-low,.quota.quota-empty{color:#E94F37;border-color:#f1b4a8;background:#fff5f2}\n.topbar-actions{display:flex;align-items:center;gap:8px}\n.topbar-actions button{height:36px;padding:0 13px;border-radius:12px;font-size:12px;color:#303741;border:1px solid #dfe4ea;background:#fff;box-shadow:0 1px 2px rgba(16,24,40,.04)}\n.topbar-actions button:hover{background:#f0f3f6}\n.upload-hidden{display:none}\n\n.panels{flex:1;min-height:0;overflow-y:auto;padding:22px 26px 32px;display:flex;flex-direction:column;gap:18px}\n.panel{background:#fff;border:1px solid #e3e7ec;border-radius:22px;box-shadow:0 12px 36px rgba(22,29,37,.06);display:flex;flex-direction:column;min-height:0;overflow:hidden}\n.panel.summary{order:1;min-height:240px}.panel.transcript{order:2;min-height:340px}body.live-note .panel.transcript{order:1;min-height:520px}body.live-note .panel.summary{order:2;min-height:180px}\n.panel-hd{min-height:56px;padding:16px 20px 10px;font-size:12px;color:#707882;text-transform:none;letter-spacing:0;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #eef1f4;background:#fff}\n.panel-hd span:first-child{font-size:15px;color:#14171b;font-weight:700;letter-spacing:0}\n.panel-hd .hint{color:#7a838e;font-size:12px;font-weight:500}\n.panel-body{flex:1;overflow-y:auto;padding:16px 20px 20px;min-height:0}\n.empty{padding:36px 18px;text-align:center;color:#8a939e;font-size:13px;line-height:1.7}\n\n.summary-item{padding:0;margin:0 0 18px;background:transparent;border-bottom:1px solid #eef1f4;padding-bottom:18px}\n.summary-item:last-child{border-bottom:0;margin-bottom:0;padding-bottom:0}\n.summary-window{display:inline-flex;align-items:center;height:24px;padding:0 9px;border-radius:999px;background:#f0f3f6;color:#6d7682;font-size:11px;font-weight:600;margin-bottom:10px;font-variant-numeric:tabular-nums}\n.summary-narrative{font-size:15px;line-height:1.8;color:#1d232a;margin-bottom:10px;font-weight:450}\n.summary-list{list-style:none;padding:0;margin:8px 0 0;display:grid;gap:7px}\n.summary-list li{padding:9px 10px 9px 28px;position:relative;color:#333b45;font-size:13px;line-height:1.55;background:#f7f9fb;border:1px solid #edf1f5;border-radius:12px}\n.summary-list li::before{content:\"\";position:absolute;left:11px;top:17px;width:6px;height:6px;border-radius:50%;background:#E94F37}\n\n.transcript{border-bottom:none}\n.utterance{padding:11px 0;margin:0;background:transparent;border-bottom:1px solid #f0f2f5;line-height:1.65}\n.utterance:last-child{border-bottom:0}\n.utterance.first-of-speaker{margin-top:4px}\n.utterance-head{display:flex;align-items:center;gap:8px;margin-bottom:5px}\n.utterance-speaker{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;letter-spacing:.02em;line-height:1.2}\n.utterance-speaker.hue-0{background:#E9F2FF;color:#1A4E8A}.utterance-speaker.hue-1{background:#FDECEC;color:#9B2A2A}.utterance-speaker.hue-2{background:#ECF7EB;color:#2F6B2F}.utterance-speaker.hue-3{background:#FFF4E0;color:#8A5A1A}.utterance-speaker.hue-4{background:#F2EBFA;color:#553080}.utterance-speaker.hue-5{background:#E5F6F7;color:#1F5E66}.utterance-speaker.hue-x{background:#EEF0F2;color:#5D6671}\n.utterance-time{font-size:11px;color:#89929e;font-variant-numeric:tabular-nums}\n.utterance-text{font-size:14px;color:#20262d;line-height:1.8}\n\n.utterance-markers{display:flex;flex-wrap:wrap;gap:6px;margin:5px 0 2px}\n.utterance-marker{display:inline-flex;align-items:center;gap:4px;height:22px;padding:0 8px;border-radius:999px;background:#fff5f2;border:1px solid #f1b4a8;color:#b42318;font-size:11px;font-weight:700;font-variant-numeric:tabular-nums}\n\n.recordings{border-bottom:1px solid #eef1f4;padding:14px 20px 12px;background:#fbfcfd}\n.recordings[hidden]{display:none}\n.recordings-hd{font-size:12px;color:#707882;text-transform:none;letter-spacing:0;margin-bottom:9px;display:flex;justify-content:space-between;align-items:center;font-weight:700}\n.recordings-hd .hint{font-size:11px;font-weight:500;color:#88919c}\n.recording-card{background:#fff;border:1px solid #e5e9ee;border-radius:16px;padding:10px 12px;margin:7px 0;display:grid;grid-template-columns:minmax(260px,1fr) auto;gap:12px;align-items:center;box-shadow:0 4px 14px rgba(16,24,40,.04)}\n.recording-audio{width:100%;height:36px;min-width:0}\n.recording-tools{display:flex;gap:7px;justify-content:flex-end;flex-wrap:nowrap}\n.recording-tools button{font-size:12px;padding:6px 11px;border:1px solid #dfe4ea;border-radius:10px;color:#38414b;background:#fff;white-space:nowrap}\n.recording-tools button:hover{background:#f0f3f6}\n\n/* EchoREC Agent rail */\n.tasks{background:#fbfbfc;border-left:1px solid #e2e5e9;display:flex;flex-direction:column;min-height:0;min-width:0}\n.tasks-hd{height:64px;padding:0 18px;font-size:15px;color:#14171b;font-weight:700;display:flex;align-items:center;border-bottom:1px solid #e7eaee;text-transform:none;letter-spacing:0}\n.tasks-body{flex:1;overflow-y:auto;padding:14px 14px 18px;min-height:0;display:flex;flex-direction:column}\n.tasks-section-hd{font-size:12px;color:#707882;text-transform:none;letter-spacing:0;margin:0 0 10px 0;display:flex;justify-content:space-between;align-items:center;font-weight:700}\n.tasks-section-hd .count{font-size:11px;padding:2px 8px;border-radius:999px;background:#eef2f6;color:#59636f}\n.task-item{background:#fff;border:1px solid #e4e8ee;border-radius:16px;padding:12px;margin:8px 0;display:flex;flex-direction:column;gap:9px;box-shadow:0 4px 14px rgba(16,24,40,.04)}\n.task-item.done{opacity:.58}.task-item.done .task-text{text-decoration:line-through}.task-item.editing{gap:8px}\n.task-row{display:flex;flex-direction:column;align-items:stretch;gap:10px}\n.task-text{font-size:13px;line-height:1.6;color:#20262d;flex:1;display:flex;align-items:flex-start;gap:6px}\n.task-meta-row{display:flex;gap:6px;flex-wrap:wrap}\n.task-item-tools{display:flex;gap:6px;justify-content:flex-start;margin-top:0}\n.icon-btn{font-size:12px;padding:4px 8px;border-radius:10px;color:#707882;background:#f7f9fb;border:1px solid #edf1f5;transition:all .16s ease}\n.icon-btn:hover{background:#eef2f6;color:#20262d}.icon-btn.danger:hover{color:#d92d20;border-color:#f1b4a8;background:#fff5f2}\n.task-edit-area{width:100%;min-height:90px;font-size:13px;line-height:1.55;padding:10px 11px;border:1px solid #dfe4ea;border-radius:12px;background:#fff;color:#20262d;resize:vertical;font-family:inherit}\n.task-edit-actions{display:flex;gap:7px;justify-content:flex-end}\n.chip{font-size:11px;padding:3px 8px;border-radius:999px;background:#eef2f6;color:#59636f}.chip.owner{background:#eaf6ef;color:#167349}.chip.due{background:#fff2e2;color:#9a5a0a}.chip.draft{background:#eef2f6}.chip.dispatching{background:#fff2e2;color:#9a5a0a}.chip.done{background:#eaf6ef;color:#167349}\n.task-progress{display:flex;align-items:center;gap:7px;font-size:12px;line-height:1.4;color:#59636f;background:#f7f9fb;border:1px solid #edf1f5;border-radius:12px;padding:8px 10px;margin-top:0}\n.task-progress-dot{width:7px;height:7px;border-radius:50%;background:#a8b0ba;flex:0 0 auto}.task-progress.queued .task-progress-dot{background:#a8b0ba}.task-progress.context .task-progress-dot{background:#5b8def}.task-progress.researching .task-progress-dot{background:#f59e0b;animation:blink 1s infinite}.task-progress.generating .task-progress-dot{background:#E94F37;animation:blink 1s infinite}.task-progress.done .task-progress-dot{background:#16a064}.task-progress.failed{color:#b42318;background:#fff5f2;border-color:#f1b4a8}.task-progress.failed .task-progress-dot{background:#d92d20}.task-progress-detail{color:#7a838e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0}\n.dispatch-btn,.toggle-btn{font-size:12px;padding:7px 10px;border-radius:12px;white-space:nowrap;text-align:center;transition:background .16s ease,border-color .16s ease,box-shadow .16s ease,transform .16s ease}\n.dispatch-btn{background:#E94F37;color:#fff;box-shadow:0 8px 18px rgba(233,79,55,.20)}.dispatch-btn:hover{background:#d9432d;box-shadow:0 10px 22px rgba(233,79,55,.24);transform:translateY(-1px)}.toggle-btn{background:#f0f3f6;color:#59636f;border:1px solid #dfe4ea}.toggle-btn:hover{background:#e7ebf0;color:#20262d}\n.research-result{font-size:12px;color:#4f5965;padding:11px 12px;background:#f7f9fb;border-radius:12px;max-height:260px;overflow-y:auto;line-height:1.6;border:1px solid #edf1f5}\n.research-result p{margin:0 0 7px}.research-result p:last-child{margin-bottom:0}.research-result strong{color:#20262d;font-weight:700}.research-result em{color:#20262d}.research-result h3,.research-result h4{font-size:13px;font-weight:700;color:#20262d;margin:8px 0 4px}.research-result ul{margin:4px 0 8px;padding-left:18px}.research-result li{margin:2px 0}.research-result code{font-family:var(--ec-font-mono);font-size:11px;padding:1px 5px;border-radius:4px;background:#eef2f6;color:#20262d}.research-result pre{margin:6px 0;padding:8px 10px;border-radius:10px;background:#fff;overflow-x:auto;font-family:var(--ec-font-mono);font-size:11px;white-space:pre}.research-result a{color:#E94F37;text-decoration:underline}\n\n.agent-intro{padding:14px 14px 12px;border:1px solid #edf1f5;background:#fff;border-radius:16px;margin-bottom:12px;color:#59636f;font-size:13px;line-height:1.65}\n.agent-messages{display:flex;flex-direction:column;gap:9px;margin-bottom:14px}\n.agent-message{max-width:94%;border:1px solid #edf1f5;border-radius:16px;padding:10px 12px;font-size:13px;line-height:1.65;color:#20262d;background:#fff;box-shadow:0 4px 14px rgba(16,24,40,.04);overflow-wrap:anywhere}\n.agent-message.user{align-self:flex-end;background:#E94F37;color:#fff;border-color:#E94F37;box-shadow:0 8px 18px rgba(233,79,55,.18)}\n.agent-message.assistant{align-self:flex-start;background:#fff}.agent-message.system{align-self:center;max-width:100%;background:#fff5f2;border-color:#f1b4a8;color:#9b2a1d;font-size:12px;text-align:center;box-shadow:none}\n.agent-message-meta{font-size:11px;color:#8a939e;margin-bottom:4px}.agent-message.user .agent-message-meta{color:rgba(255,255,255,.76)}\n.agent-suggestions{display:flex;flex-direction:column;gap:8px;margin:10px 0 14px}.agent-suggestion{background:#fff;border:1px solid #e4e8ee;border-radius:16px;padding:11px 12px;display:flex;flex-direction:column;gap:8px;box-shadow:0 4px 14px rgba(16,24,40,.04)}\n.agent-suggestion-title{font-size:12px;color:#707882;font-weight:700}.agent-suggestion-text{font-size:13px;line-height:1.55;color:#20262d}.agent-suggestion-tools{display:flex;gap:6px;flex-wrap:wrap}\n.agent-composer{position:sticky;bottom:0;background:linear-gradient(to bottom,rgba(251,251,252,0),#fbfbfc 18px,#fbfbfc);padding-top:18px;margin-top:8px;display:flex;flex-direction:column;gap:8px}\n.agent-input{width:100%;min-height:74px;resize:vertical;border:1px solid #dfe4ea;border-radius:14px;background:#fff;padding:10px 11px;font-size:13px;line-height:1.55;font-family:inherit;color:#20262d;box-shadow:0 1px 2px rgba(16,24,40,.04)}\n.agent-input:focus{outline:none;border-color:#E94F37;box-shadow:0 0 0 3px rgba(233,79,55,.12)}\n.agent-composer-actions{display:flex;align-items:center;justify-content:space-between;gap:10px}.agent-hint{font-size:11px;color:#8a939e;line-height:1.4}.agent-run-status{font-size:12px;line-height:1.45;color:#59636f;background:#f7f9fb;border:1px solid #edf1f5;border-radius:12px;padding:8px 10px;display:flex;gap:7px;align-items:center}.agent-run-status.failed{background:#fff5f2;border-color:#f1b4a8;color:#b42318}\n\n.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:#111418;color:#fff;border:1px solid rgba(255,255,255,.08);padding:10px 15px;border-radius:999px;font-size:13px;box-shadow:0 12px 32px rgba(16,24,40,.24);z-index:100;opacity:0;pointer-events:none;transition:opacity .18s ease}\n.toast.show{opacity:1}.toast.error{background:#b42318;color:#fff;border-color:#b42318}\n@media (max-width:1180px){.app{grid-template-columns:260px minmax(460px,1fr)}.tasks{display:none}}\n@media (max-width:860px){.app{grid-template-columns:1fr}.sidebar{display:none}.topbar{padding:0 14px}.panels{padding:16px}.recording-card{grid-template-columns:1fr}.recording-tools{justify-content:flex-start}}\n\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <!-- ═══ Sidebar ═══ -->\n  <aside class=\"sidebar\">\n    <div class=\"brand\">\n      <div class=\"brand-logo\">E</div>\n      <div class=\"brand-name\">EchoREC</div>\n    </div>\n    <div class=\"sidebar-hd\">\n      <span>录音笔记</span>\n      <button id=\"btn-new-session\" aria-label=\"新建会话\">+</button>\n    </div>\n    <div class=\"session-list\" id=\"session-list\"></div>\n  </aside>\n\n  <!-- ═══ Main ═══ -->\n  <main class=\"main\">\n\n    <section class=\"home-screen\" id=\"home-screen\">\n      <div class=\"home-shell\">\n        <div class=\"home-hero\">\n          <div>\n            <div class=\"home-kicker\">EchoREC</div>\n            <h1 class=\"home-title\">EchoREC</h1>\n            <p class=\"home-subtitle\">录音时实时转写，结束后自动整理摘要；进入具体录音后，EchoREC Agent 会结合逐字稿、重点标记和摘要继续处理后续需求。</p>\n            <div class=\"home-actions\">\n              <button class=\"home-primary\" id=\"home-start-recording\">开始录音</button>\n              <button class=\"home-secondary\" id=\"home-upload-audio\">上传音频</button>\n            </div>\n          </div>\n          <div class=\"home-meter\">\n            <div class=\"home-meter-label\">今日 ASR 剩余额度</div>\n            <div class=\"home-meter-value\" id=\"home-quota\">--:--</div>\n            <div class=\"home-meter-note\">每天 60 分钟免费额度。</div>\n          </div>\n        </div>\n        <div class=\"home-history\">\n          <div class=\"home-history-head\">\n            <div class=\"home-history-title\">录音记录</div>\n            <div class=\"home-history-count\" id=\"home-history-count\"></div>\n          </div>\n          <div class=\"home-session-list\" id=\"home-session-list\"></div>\n        </div>\n      </div>\n    </section>\n    <header class=\"topbar\">\n      <button class=\"mic-btn\" id=\"btn-mic\" aria-label=\"开始 / 暂停\" disabled>\n        <svg class=\"ic-mic\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">\n          <path d=\"M12 14a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v5a3 3 0 0 0 3 3Zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11h-2Z\"/>\n        </svg>\n        <svg class=\"ic-pause\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">\n          <rect x=\"6\" y=\"5\" width=\"4\" height=\"14\" rx=\"1\"/><rect x=\"14\" y=\"5\" width=\"4\" height=\"14\" rx=\"1\"/>\n        </svg>\n      </button>\n      <button class=\"stop-btn\" id=\"btn-stop\" aria-label=\"结束会话\" style=\"display:none\">\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">\n          <rect x=\"6\" y=\"6\" width=\"12\" height=\"12\" rx=\"2\"/>\n        </svg>\n      </button>\n      <div class=\"status\">\n        <span class=\"dot\" id=\"status-dot\"></span>\n        <span id=\"status-text\">未开始</span>\n        <span class=\"timer\" id=\"timer\">00:00</span>\n      </div>\n      <div class=\"topbar-actions\">\n        <span class=\"quota\" id=\"quota-indicator\" title=\"服务端 ASR 用量额度（每天 1 小时上限）\"></span>\n        <button id=\"btn-upload\" aria-label=\"上传音频文件\">上传音频</button>\n        <input type=\"file\" id=\"file-input\" accept=\"audio/*\" class=\"upload-hidden\">\n      </div>\n    </header>\n\n    <div class=\"panels\">\n      <section class=\"panel summary\">\n        <div class=\"panel-hd\">\n          <span>AI 摘要</span>\n          <span class=\"hint\">自动整理要点与线索</span>\n        </div>\n        <div class=\"panel-body\" id=\"summary-body\">\n          <div class=\"empty\">录音结束后生成摘要</div>\n        </div>\n      </section>\n      <section class=\"panel transcript\">\n        <div class=\"panel-hd\">\n          <span>逐字稿</span>\n          <span class=\"hint\" id=\"transcript-hint\"></span>\n        </div>\n        <div class=\"recordings\" hidden>\n          <div class=\"recordings-hd\">录音文件 <span class=\"hint\" id=\"audio-summary\"></span></div>\n          <div id=\"audio-files\"></div>\n        </div>\n        <div class=\"panel-body\" id=\"transcript-body\">\n          <div class=\"empty\">等待录音内容</div>\n        </div>\n      </section>\n    </div>\n  </main>\n\n  <!-- ═══ EchoREC Agent unified chat ═══ -->\n  <aside class=\"tasks\">\n    <div class=\"tasks-hd\">EchoREC Agent</div>\n    <div class=\"tasks-body\" id=\"tasks-body\">\n      <div class=\"empty\">EchoREC Agent 正在准备会议上下文</div>\n    </div>\n  </aside>\n</div>\n<div class=\"toast\" id=\"toast\"></div>\n<script>\n'use strict';\n(function () {\n\n/* ═══ Constants ═══ */\n/* EchoCoding shared proxy — same endpoint + managed HMAC key as the\n   EchoCoding CLI's default managed-proxy flow (see EchoCoding src/auth.ts\n   MANAGED_KEY + proxy/server.js VOLC_ASR_WS_URL path). */\n// ASR backend: EchoBraid signed quota proxy. Desktop signs a short-lived\n// ticket via asr:get_ws_ticket; the server meters actual Float32 audio seconds\n// per device and pushes quota frames back to this app.\nconst ASR_SIGNED_PATH = '/v2/asr/stream';\n\nconst SAMPLE_RATE = 16000;\n// 240ms block size to match the xiaozhi reference client (their VAD is tuned\n// around this cadence; at 200ms we saw no utterances emitted in testing).\nconst FRAME_MS = 240;\nconst FRAME_SAMPLES = SAMPLE_RATE * FRAME_MS / 1000;\nconst SUMMARY_INTERVAL_MS = 60000;\nconst SUMMARY_CHAR_THRESHOLD = 200;\n// Absolute-safety cap, NOT the expected number. Prompt rule 3 tells the LLM\n// the typical count is 0-3; 5 leaves headroom so legit edge-case meetings\n// (big design review with many open branches) aren't silently truncated —\n// but once hit, further research items are dropped + logged.\nconst MAX_RESEARCH_PER_SESSION = 5;\nconst WS_CHANNEL = 'ec-asr';\nconst WS_QUOTA_CHANNEL = 'ec-asr-quota';\n\n/* ═══ Utilities ═══ */\nfunction uuid() {\n  if (crypto.randomUUID) return crypto.randomUUID();\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n    const r = Math.random() * 16 | 0;\n    return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n  });\n}\nconst nowMs = () => Date.now();\nfunction escapeHtml(s) {\n  return String(s).replace(/[&<>\"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[ch]));\n}\nfunction fmtDuration(ms) {\n  if (!ms || ms < 0) ms = 0;\n  const s = Math.floor(ms / 1000);\n  return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0');\n}\nfunction fmtDate(ms) {\n  const d = new Date(ms);\n  return (d.getMonth()+1) + '月' + d.getDate() + '日 ' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');\n}\nlet toastTimer = null;\nfunction toast(msg, kind) {\n  const t = document.getElementById('toast');\n  t.textContent = msg;\n  t.className = 'toast show ' + (kind || '');\n  clearTimeout(toastTimer);\n  toastTimer = setTimeout(() => { t.className = 'toast'; }, 2800);\n}\nfunction safeParse(s, fb) { try { return JSON.parse(s); } catch { return fb; } }\n\n/* Unified DB-error reporter. Previously we used .catch(()=>{}) which silently\n   swallowed writes — the UI would look fine but data would vanish on reload.\n   Now we log every failure and surface one toast per session so the user knows. */\nlet dbErrorNotified = false;\nfunction reportDbErr(op, e) {\n  try { log('db', op, 'FAIL', e && e.message || e); } catch {}\n  if (!dbErrorNotified) {\n    dbErrorNotified = true;\n    try { toast('本地存储异常，部分数据可能未保存', 'error'); } catch {}\n  }\n}\n\n/* ═══ Minimal markdown renderer (inline, no dependency) ═══ */\nfunction renderMarkdown(text) {\n  if (!text) return '';\n  // 1. Escape HTML first, all replacements operate on escaped text\n  let html = escapeHtml(text);\n  // 2. Protect fenced code blocks by extracting placeholders\n  const codeBlocks = [];\n  html = html.replace(/```([\\s\\S]*?)```/g, (_, c) => {\n    codeBlocks.push(c);\n    return '\\u0000CODEBLOCK' + (codeBlocks.length - 1) + '\\u0000';\n  });\n  // 3. Inline code\n  html = html.replace(/`([^`\\n]+)`/g, '<code>$1</code>');\n  // 4. Bold then italic (bold first to avoid *foo* eating **foo**)\n  html = html.replace(/\\*\\*([^\\n]+?)\\*\\*/g, '<strong>$1</strong>');\n  html = html.replace(/(^|[^\\*])\\*([^\\*\\n]+?)\\*(?!\\*)/g, '$1<em>$2</em>');\n  // 5. Headings\n  html = html.replace(/^#### (.+)$/gm, '<h4>$1</h4>');\n  html = html.replace(/^### (.+)$/gm, '<h4>$1</h4>');\n  html = html.replace(/^## (.+)$/gm, '<h3>$1</h3>');\n  html = html.replace(/^# (.+)$/gm, '<h3>$1</h3>');\n  // 6. Bullet / numbered list items\n  html = html.replace(/^[-*+] (.+)$/gm, '<liX>$1</liX>');\n  html = html.replace(/^\\d+\\. (.+)$/gm, '<liX>$1</liX>');\n  // Wrap consecutive <liX> into <ul>\n  html = html.replace(/(?:<liX>.*<\\/liX>(?:\\n|$))+/g, (m) =>\n    '<ul>' + m.replace(/<liX>/g, '<li>').replace(/<\\/liX>/g, '</li>').replace(/\\n$/, '') + '</ul>'\n  );\n  // 7. Links [text](url) — restrict to http/https to block javascript: /\n  //    data: / vbscript: injection from LLM-generated markdown.\n  const sanitizeUrl = (u) => {\n    try {\n      const p = new URL(u, 'https://dummy.local');\n      const proto = p.protocol.toLowerCase();\n      if (proto === 'http:' || proto === 'https:' || proto === 'mailto:') return p.href;\n      return '#';\n    } catch { return '#'; }\n  };\n  html = html.replace(/\\[([^\\]]+)\\]\\(([^)\\s]+)\\)/g, (_, label, url) => {\n    const safe = sanitizeUrl(url);\n    return '<a href=\"' + safe + '\" target=\"_blank\" rel=\"noopener noreferrer\">' + label + '</a>';\n  });\n  // 8. Paragraph breaks and line breaks\n  const parts = html.split(/\\n{2,}/).map(p => {\n    const trimmed = p.trim();\n    if (!trimmed) return '';\n    // Blocks (headings/lists/code) should not be wrapped in <p>\n    if (/^<(h[1-6]|ul|ol|pre)/.test(trimmed)) return trimmed;\n    return '<p>' + trimmed.replace(/\\n/g, '<br>') + '</p>';\n  });\n  html = parts.join('');\n  // 9. Restore code blocks\n  html = html.replace(/\\u0000CODEBLOCK(\\d+)\\u0000/g, (_, i) => '<pre>' + codeBlocks[Number(i)] + '</pre>');\n  return html;\n}\n\n/* ═══ Debug log ═══ */\nconst LOG_MAX = 300;\nconst logEntries = [];\nfunction log() { /* debug log panel removed; stub kept to keep callsites no-op */ }\n\n/* ═══ WS ticket from Desktop bridge ═══ */\n/* ═══ State ═══ */\nconst appState = {\n  sessions: [], currentSessionId: null,\n  segments: [], summaries: [],\n  // Global (cross-window, deduped) collectors — these three surface in the\n  // right-hand \"汇总任务\" panel, not inside each summary chunk, so rapid\n  // session chatter doesn't fragment actionables into micro-lists.\n  actions: [], questions: [], research: [], dispatchProgress: {},\n  markers: [], agentMessages: [], agentRuns: [], agentProgress: {},\n  audioFiles: [], audioArchive: null, audioUrls: {},\n  recording: false, wsConnected: false, tearingDown: false,\n  wsReconnectTimer: null, wsReconnectAttempts: 0,\n  audioCtx: null, mediaStream: null, workletNode: null,\n  // xiaozhi wants raw Float32 LE @ 16kHz. We still batch to 200ms chunks\n  // to keep the bridge happy (worklet's native 128-sample cadence would flood it).\n  pcmBuffer: new Float32Array(FRAME_SAMPLES), pcmBufferFill: 0,\n  recordStartMs: 0, timerHandle: null, summaryTimerHandle: null,\n  quotaRemainingSeconds: null,\n  lastSummaryAt: 0, lastSummaryCharCount: 0,\n  summaryInFlight: false, summaryRetryAfterMs: 0,\n  lastFinalEndMs: 0,\n};\n\n\n/* ═══ Server ASR quota ═══\n   The authoritative 60min/day limit lives in apps/asr-proxy. This UI only\n   displays server-pushed remaining seconds; client-side storage is not trusted. */\nfunction updateQuotaFromServer(seconds) {\n  const n = Number(seconds);\n  if (Number.isFinite(n)) appState.quotaRemainingSeconds = Math.max(0, Math.floor(n));\n  renderQuotaIndicator();\n}\nfunction quotaRemainingSeconds() {\n  return appState.quotaRemainingSeconds == null ? null : appState.quotaRemainingSeconds;\n}\nfunction fmtMmSs(s) {\n  const v = Math.max(0, Math.floor(s));\n  return String(Math.floor(v / 60)).padStart(2, '0') + ':' +\n         String(v % 60).padStart(2, '0');\n}\nfunction renderQuotaIndicator() {\n  const el = document.getElementById('quota-indicator');\n  const homeQuota = document.getElementById('home-quota');\n  const remain = quotaRemainingSeconds();\n  const displayRemain = remain == null ? 60 * 60 : remain;\n  if (el) {\n    el.textContent = '今日剩余 ' + fmtMmSs(displayRemain);\n    el.classList.toggle('quota-low', remain != null && remain <= 300 && remain > 0);\n    el.classList.toggle('quota-empty', remain != null && remain <= 0);\n  }\n  if (homeQuota) homeQuota.textContent = fmtMmSs(displayRemain);\n}\nasync function buildSignedWsUrl() {\n  const r = await echobraid.invoke('asr:get_ws_ticket', { path: ASR_SIGNED_PATH });\n  if (r && r.__error) {\n    throw new Error(r.__error === 'RATE_LIMITED'\n      ? 'ASR 连接过于频繁，请稍后再试'\n      : (r.message || r.__error));\n  }\n  if (!r || !r.url) throw new Error('ASR ticket 返回空 url');\n  return r.url;\n}\nasync function refreshQuotaFromServer() {\n  try {\n    const url = await buildSignedWsUrl();\n    const result = await echobraid.ws.connect(WS_QUOTA_CHANNEL, { url });\n    if (!result || !result.connected) {\n      log('quota', 'prefetch connect failed', result && (result.__error || result.error || result.message) || 'unknown');\n      return;\n    }\n    setTimeout(() => { try { echobraid.ws.close(WS_QUOTA_CHANNEL); } catch {} }, 5000);\n  } catch (e) {\n    log('quota', 'prefetch FAIL', e && e.message || e);\n  }\n}\nfunction maybeHandleQuotaMessage(raw, channel) {\n  let msg;\n  try { msg = JSON.parse(raw); } catch { return false; }\n  if (!msg || typeof msg !== 'object' || msg.type !== 'quota') return false;\n  updateQuotaFromServer(msg.remainingSeconds);\n  if (channel === WS_QUOTA_CHANNEL) {\n    try { echobraid.ws.close(WS_QUOTA_CHANNEL); } catch {}\n  }\n  if (msg.error === 'ASR_QUOTA_EXCEEDED') {\n    toast('今日 ASR 用量已达 1 小时上限，请明天再试', 'error');\n    setStatus('error', '今日额度已用完');\n    if (appState.recording) pauseRecording();\n  }\n  return true;\n}\n\n/* ═══ Local audio archive ═══ */\nfunction fmtBytes(bytes) {\n  const n = Number(bytes) || 0;\n  if (n < 1024) return n + ' B';\n  if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';\n  return (n / 1024 / 1024).toFixed(1) + ' MB';\n}\nfunction padPart(n) { return String(n || 1).padStart(3, '0'); }\nfunction int16FromFloat(v) {\n  const x = Math.max(-1, Math.min(1, v));\n  return x < 0 ? Math.round(x * 32768) : Math.round(x * 32767);\n}\nfunction appendAudioFrameBuffer(buf) {\n  const archive = appState.audioArchive;\n  if (!archive || !buf || !buf.byteLength) return;\n  const f32 = new Float32Array(buf);\n  const i16 = new Int16Array(f32.length);\n  for (let i = 0; i < f32.length; i++) i16[i] = int16FromFloat(f32[i]);\n  archive.chunks.push(i16);\n  archive.sampleCount += i16.length;\n}\nfunction buildWavHeader(sampleCount) {\n  const dataBytes = sampleCount * 2;\n  const out = new Uint8Array(44);\n  const view = new DataView(out.buffer);\n  function str(off, s) { for (let i = 0; i < s.length; i++) out[off + i] = s.charCodeAt(i); }\n  str(0, 'RIFF'); view.setUint32(4, 36 + dataBytes, true); str(8, 'WAVE');\n  str(12, 'fmt '); view.setUint32(16, 16, true); view.setUint16(20, 1, true);\n  view.setUint16(22, 1, true); view.setUint32(24, SAMPLE_RATE, true);\n  view.setUint32(28, SAMPLE_RATE * 2, true); view.setUint16(32, 2, true); view.setUint16(34, 16, true);\n  str(36, 'data'); view.setUint32(40, dataBytes, true);\n  return out;\n}\nfunction int16ChunkToBytes(chunk) {\n  const bytes = new Uint8Array(chunk.length * 2);\n  const view = new DataView(bytes.buffer);\n  for (let i = 0, off = 0; i < chunk.length; i++, off += 2) view.setInt16(off, chunk[i], true);\n  return bytes;\n}\nfunction concatBytes(parts, total) {\n  const out = new Uint8Array(total);\n  let offset = 0;\n  for (const part of parts) { out.set(part, offset); offset += part.length; }\n  return out;\n}\nfunction bytesToBase64(bytes) {\n  let binary = '';\n  const step = 0x8000;\n  for (let i = 0; i < bytes.length; i += step) {\n    binary += String.fromCharCode.apply(null, bytes.subarray(i, i + step));\n  }\n  return btoa(binary);\n}\nasync function sha256Hex(bytes) {\n  if (!crypto.subtle) return null;\n  const hash = await crypto.subtle.digest('SHA-256', bytes);\n  return Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, '0')).join('');\n}\nasync function fsAppWriteBase64(path, base64) {\n  const res = await echobraid.invoke('fs.appWrite', { path, content: base64, encoding: 'base64' });\n  if (res && res.__error) throw new Error(res.message || res.__error);\n  return res || { success: true };\n}\nasync function fsAppAppendBase64(path, base64) {\n  const res = await echobraid.invoke('fs.appAppend', { path, content: base64, encoding: 'base64' });\n  if (res && res.__error) throw new Error(res.message || res.__error);\n  return res || { success: true };\n}\nasync function writeWavFile(path, chunks, sampleCount) {\n  await fsAppWriteBase64(path, bytesToBase64(buildWavHeader(sampleCount)));\n  let parts = [];\n  let total = 0;\n  let lastResult = { size: 44 };\n  const flush = async () => {\n    if (!total) return;\n    lastResult = await fsAppAppendBase64(path, bytesToBase64(concatBytes(parts, total)));\n    parts = []; total = 0;\n  };\n  for (const chunk of chunks) {\n    const bytes = int16ChunkToBytes(chunk);\n    parts.push(bytes);\n    total += bytes.length;\n    if (total >= 768 * 1024) await flush();\n  }\n  await flush();\n  return lastResult;\n}\nasync function fsAppReadBase64(path) {\n  const res = await echobraid.invoke('fs.appRead', { path, encoding: 'base64' });\n  if (res && res.__error) throw new Error(res.message || res.__error);\n  return typeof res === 'string' ? res : '';\n}\nfunction base64ToBytes(base64) {\n  const raw = atob(base64 || '');\n  const bytes = new Uint8Array(raw.length);\n  for (let i = 0; i < raw.length; i++) bytes[i] = raw.charCodeAt(i);\n  return bytes;\n}\nasync function audioFileToBytes(file) {\n  return base64ToBytes(await fsAppReadBase64(file.path));\n}\nasync function buildCombinedAudioBytes(files) {\n  const sorted = (files || []).slice().sort((a, b) => (Number(a.created_at) || 0) - (Number(b.created_at) || 0));\n  const pcmParts = [];\n  let total = 0;\n  for (const f of sorted) {\n    const bytes = await audioFileToBytes(f);\n    if (bytes.length <= 44) continue;\n    const data = bytes.subarray(44);\n    pcmParts.push(data);\n    total += data.length;\n  }\n  const header = buildWavHeader(Math.floor(total / 2));\n  return concatBytes([header, ...pcmParts], header.length + total);\n}\nasync function exportCombinedAudioFiles() {\n  const files = appState.audioFiles || [];\n  if (!files.length) return;\n  try {\n    if (echobraid.requestPermission) await echobraid.requestPermission('filesystem');\n    const bytes = await buildCombinedAudioBytes(files);\n    const relPath = 'recordings/' + appState.currentSessionId + '/combined-export.wav';\n    await fsAppWriteBase64(relPath, bytesToBase64(bytes));\n    const session = appState.sessions.find(s => s.id === appState.currentSessionId);\n    const name = ((session && session.title) || 'recording').replace(/[\\/:*?\"<>|]/g, '-') + '.wav';\n    const res = await echobraid.invoke('fs.saveAppFile', { path: relPath, defaultName: name, accept: '.wav' });\n    if (res && res.saved) toast('录音文件已导出');\n  } catch (e) {\n    toast('导出失败：' + (e && e.message || e), 'error');\n  }\n}\nasync function beginAudioArchive(source) {\n  if (!appState.currentSessionId) return;\n  if (appState.audioArchive && appState.audioArchive.sessionId === appState.currentSessionId) return;\n  const rows = await echobraid.db.query('SELECT COUNT(*) AS count FROM audio_files WHERE session_id=?', [appState.currentSessionId]).catch(() => [{ count: 0 }]);\n  const count = Number(rows && rows[0] && rows[0].count) || 0;\n  appState.audioArchive = {\n    sessionId: appState.currentSessionId,\n    source: source || 'mic',\n    part: count + 1,\n    startedAt: nowMs(),\n    chunks: [],\n    sampleCount: 0,\n  };\n}\nfunction waitSendQueueIdle() {\n  return new Promise(resolve => {\n    const deadline = Date.now() + 5000;\n    const check = () => {\n      if (!sendInFlight && sendQueue.length === 0) resolve();\n      else if (Date.now() > deadline) resolve();\n      else setTimeout(check, 40);\n    };\n    check();\n  });\n}\nasync function finalizeAudioArchive() {\n  const archive = appState.audioArchive;\n  appState.audioArchive = null;\n  if (!archive || !archive.sessionId || archive.sampleCount <= 0) return;\n  const name = 'part-' + padPart(archive.part) + '.wav';\n  const relPath = 'recordings/' + archive.sessionId + '/' + name;\n  let writeResult;\n  try {\n    writeResult = await writeWavFile(relPath, archive.chunks, archive.sampleCount);\n  } catch (e) {\n    toast('录音文件保存失败：' + (e && e.message || e), 'error');\n    return;\n  }\n  const durationMs = Math.round(archive.sampleCount / SAMPLE_RATE * 1000);\n  await dbInsertAudioFile({\n    id: uuid(), session_id: archive.sessionId, path: relPath, name,\n    mime: 'audio/wav', size_bytes: Number(writeResult && writeResult.size) || (44 + archive.sampleCount * 2),\n    duration_ms: durationMs, sample_rate: SAMPLE_RATE, source: archive.source,\n    created_at: archive.startedAt, sha256: null,\n  });\n  await dbLoadSessions();\n  if (appState.currentSessionId === archive.sessionId) await dbLoadAudioFiles(archive.sessionId);\n  renderSessions();\n  renderAudioFiles();\n}\nfunction revokeAudioUrls() {\n  Object.values(appState.audioUrls || {}).forEach(url => { try { URL.revokeObjectURL(url); } catch {} });\n  appState.audioUrls = {};\n}\nasync function attachAudioSources() {\n  const nodes = Array.from(document.querySelectorAll('audio[data-audio-id]'));\n  for (const node of nodes) {\n    const id = node.dataset.audioId;\n    if (appState.audioUrls[id]) continue;\n    try {\n      let bytes;\n      if (id === '__combined__') {\n        bytes = await buildCombinedAudioBytes(appState.audioFiles || []);\n      } else {\n        const file = appState.audioFiles.find(f => f.id === id);\n        if (!file) continue;\n        bytes = await audioFileToBytes(file);\n      }\n      const url = URL.createObjectURL(new Blob([bytes], { type: 'audio/wav' }));\n      appState.audioUrls[id] = url;\n      node.src = url;\n    } catch (e) {\n      node.replaceWith(document.createTextNode('读取失败'));\n    }\n  }\n}\nfunction currentSessionFinalized() {\n  if (!appState.currentSessionId) return false;\n  const s = appState.sessions.find(x => x.id === appState.currentSessionId);\n  return !!(s && Number(s.finalized_at));\n}\nfunction renderAudioFiles() {\n  const panel = document.querySelector('.recordings');\n  const wrap = document.getElementById('audio-files');\n  const summary = document.getElementById('audio-summary');\n  if (!panel || !wrap || !summary) return;\n  revokeAudioUrls();\n  const files = appState.audioFiles || [];\n  const showPanel = !appState.recording && currentSessionFinalized() && files.length > 0;\n  panel.hidden = !showPanel;\n  if (!showPanel) {\n    summary.textContent = '';\n    wrap.innerHTML = '';\n    return;\n  }\n  const totalBytes = files.reduce((sum, f) => sum + (Number(f.size_bytes) || 0), 0);\n  const totalMs = files.reduce((sum, f) => sum + (Number(f.duration_ms) || 0), 0);\n  summary.textContent = '整段录音 · ' + fmtDuration(totalMs) + ' · ' + fmtBytes(totalBytes);\n  wrap.innerHTML = '<div class=\"recording-card\" data-id=\"__combined__\">' +\n    '<audio class=\"recording-audio\" controls preload=\"metadata\" data-audio-id=\"__combined__\"></audio>' +\n    '<div class=\"recording-tools\">' +\n      '<button data-action=\"export-audio\" data-id=\"__combined__\">导出音频</button>' +\n    '</div>' +\n  '</div>';\n  wrap.querySelectorAll('[data-action=\"export-audio\"]').forEach(btn => btn.addEventListener('click', () => exportAudioFile(btn.dataset.id)));\n  attachAudioSources();\n}\nasync function exportAudioFile(id) {\n  if (id === '__combined__') return exportCombinedAudioFiles();\n  const file = appState.audioFiles.find(f => f.id === id);\n  if (!file) return;\n  try {\n    if (echobraid.requestPermission) await echobraid.requestPermission('filesystem');\n    const res = await echobraid.invoke('fs.saveAppFile', {\n      path: file.path, defaultName: file.name || 'recording.wav', accept: '.wav',\n    });\n    if (res && res.saved) toast('录音文件已导出');\n  } catch (e) {\n    toast('导出失败：' + (e && e.message || e), 'error');\n  }\n}\nasync function deleteAudioFile(id) {\n  if (appState.recording) { toast('录音中不能删除文件'); return; }\n  const file = appState.audioFiles.find(f => f.id === id);\n  if (!file) return;\n  if (!confirm('删除本地录音文件？此操作不可撤销。')) return;\n  try { await echobraid.invoke('fs.appRemove', { path: file.path }); } catch {}\n  await dbDeleteAudioFile(id);\n  await dbLoadSessions();\n  if (appState.currentSessionId) await dbLoadAudioFiles(appState.currentSessionId);\n  renderSessions();\n  renderAudioFiles();\n}\n\n/* ═══ SQLite ═══ */\nasync function dbInit() {\n  await echobraid.db.exec(`CREATE TABLE IF NOT EXISTS sessions(\n    id TEXT PRIMARY KEY, started_at INTEGER, duration_ms INTEGER DEFAULT 0,\n    source TEXT, status TEXT, title TEXT, finalized_at INTEGER)`);\n  try { await echobraid.db.exec('ALTER TABLE sessions ADD COLUMN finalized_at INTEGER'); } catch {}\n  await echobraid.db.exec(`CREATE TABLE IF NOT EXISTS segments(\n    id INTEGER PRIMARY KEY AUTOINCREMENT, session_id TEXT,\n    start_ms INTEGER, end_ms INTEGER, text TEXT, is_definite INTEGER,\n    speaker TEXT)`);\n  await echobraid.db.exec(`CREATE INDEX IF NOT EXISTS idx_seg_session ON segments(session_id)`);\n  // Upgrade path: older installs have segments without the speaker column.\n  // SQLite has no ADD COLUMN IF NOT EXISTS; swallow the \"duplicate column\" error.\n  try { await echobraid.db.exec('ALTER TABLE segments ADD COLUMN speaker TEXT'); } catch {}\n  await echobraid.db.exec(`CREATE TABLE IF NOT EXISTS summaries(\n    id INTEGER PRIMARY KEY AUTOINCREMENT, session_id TEXT,\n    window_start_ms INTEGER, window_end_ms INTEGER,\n    bullets_json TEXT, research_json TEXT, created_at INTEGER)`);\n  await echobraid.db.exec(`CREATE TABLE IF NOT EXISTS research(\n    id TEXT PRIMARY KEY, session_id TEXT, text TEXT, status TEXT,\n    result TEXT, created_at INTEGER, evidence TEXT)`);\n  // Add evidence column to pre-existing research tables (upgrade path).\n  // SQLite doesn't support ALTER TABLE ... ADD COLUMN IF NOT EXISTS, so we\n  // tolerate the \"duplicate column\" error on subsequent runs.\n  try { await echobraid.db.exec('ALTER TABLE research ADD COLUMN evidence TEXT'); } catch {}\n  await echobraid.db.exec(`CREATE TABLE IF NOT EXISTS actions(\n    id TEXT PRIMARY KEY, session_id TEXT, task TEXT, owner TEXT,\n    due TEXT, evidence TEXT, done INTEGER DEFAULT 0, created_at INTEGER)`);\n  await echobraid.db.exec(`CREATE TABLE IF NOT EXISTS questions(\n    id TEXT PRIMARY KEY, session_id TEXT, text TEXT, evidence TEXT,\n    resolved INTEGER DEFAULT 0, created_at INTEGER)`);\n  await echobraid.db.exec(`CREATE TABLE IF NOT EXISTS audio_files(\n    id TEXT PRIMARY KEY, session_id TEXT, path TEXT UNIQUE, name TEXT,\n    mime TEXT, size_bytes INTEGER, duration_ms INTEGER, sample_rate INTEGER,\n    source TEXT, created_at INTEGER, sha256 TEXT)`);\n  await echobraid.db.exec(`CREATE INDEX IF NOT EXISTS idx_audio_session ON audio_files(session_id)`);\n  await echobraid.db.exec('CREATE TABLE IF NOT EXISTS markers(id TEXT PRIMARY KEY, session_id TEXT, timestamp_ms INTEGER, transcript_anchor TEXT, note TEXT, created_at INTEGER)');\n  await echobraid.db.exec('CREATE INDEX IF NOT EXISTS idx_marker_session ON markers(session_id, timestamp_ms)');\n  await echobraid.db.exec('CREATE TABLE IF NOT EXISTS agent_messages(id TEXT PRIMARY KEY, session_id TEXT, role TEXT, content TEXT, source_type TEXT, source_id TEXT, created_at INTEGER)');\n  await echobraid.db.exec('CREATE INDEX IF NOT EXISTS idx_agent_msg_session ON agent_messages(session_id, created_at)');\n  await echobraid.db.exec('CREATE TABLE IF NOT EXISTS agent_runs(id TEXT PRIMARY KEY, session_id TEXT, source_type TEXT, source_id TEXT, status TEXT, progress_json TEXT, result TEXT, error TEXT, created_at INTEGER, updated_at INTEGER)');\n  await echobraid.db.exec('CREATE INDEX IF NOT EXISTS idx_agent_run_session ON agent_runs(session_id, created_at)');\n}\n\nasync function dbLoadSessions() {\n  const rows = await echobraid.db.query(`SELECT s.*,\n    COALESCE(a.audio_count, 0) AS audio_count,\n    COALESCE(a.audio_bytes, 0) AS audio_bytes\n    FROM sessions s\n    LEFT JOIN (\n      SELECT session_id, COUNT(*) AS audio_count, COALESCE(SUM(size_bytes), 0) AS audio_bytes\n      FROM audio_files GROUP BY session_id\n    ) a ON a.session_id = s.id\n    ORDER BY s.started_at DESC`, []);\n  appState.sessions = rows || [];\n}\nasync function dbCreateSession(source) {\n  const id = uuid();\n  const ts = nowMs();\n  const title = fmtDate(ts) + ' 会话';\n  await echobraid.db.exec(\n    'INSERT INTO sessions(id, started_at, duration_ms, source, status, title) VALUES(?,?,?,?,?,?)',\n    [id, ts, 0, source, 'active', title]\n  );\n  appState.sessions.unshift({ id, started_at: ts, duration_ms: 0, source, status: 'active', title, audio_count: 0, audio_bytes: 0 });\n  appState.currentSessionId = id;\n  appState.segments = []; appState.summaries = []; appState.actions = []; appState.questions = []; appState.research = [];\n  appState.markers = []; appState.agentMessages = []; appState.agentRuns = []; appState.agentProgress = {};\n  appState.audioFiles = []; revokeAudioUrls(); renderAudioFiles();\n  return id;\n}\nasync function dbInsertSegment(seg) {\n  await echobraid.db.exec(\n    'INSERT INTO segments(session_id, start_ms, end_ms, text, is_definite, speaker) VALUES(?,?,?,?,?,?)',\n    [seg.session_id, seg.start_ms, seg.end_ms, seg.text, seg.is_definite ? 1 : 0, seg.speaker || null]\n  );\n}\nasync function dbLoadSegments(sessionId) {\n  // is_definite filter intentionally retained for back-compat with legacy\n  // proxy-era rows; all new xiaozhi rows are written with is_definite=1.\n  const rows = await echobraid.db.query(\n    'SELECT * FROM segments WHERE session_id=? AND is_definite=1 ORDER BY start_ms ASC',\n    [sessionId]\n  );\n  appState.segments = rows || [];\n}\nasync function dbInsertSummary(sm) {\n  // Pack narrative + bullets into bullets_json as a structured payload so we\n  // can extend without a schema migration. Older records (bare bullet array\n  // or legacy {bullets, decisions, actions, questions}) still parse via the\n  // fallback in dbLoadSummaries.\n  const payload = {\n    narrative: sm.narrative || '',\n    bullets: sm.bullets || [],\n  };\n  await echobraid.db.exec(\n    'INSERT INTO summaries(session_id, window_start_ms, window_end_ms, bullets_json, research_json, created_at) VALUES(?,?,?,?,?,?)',\n    [sm.session_id, sm.window_start_ms, sm.window_end_ms, JSON.stringify(payload), JSON.stringify(sm.research_items||[]), nowMs()]\n  );\n}\nasync function dbLoadSummaries(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM summaries WHERE session_id=? ORDER BY window_start_ms ASC', [sessionId]);\n  appState.summaries = (rows || []).map(r => {\n    const parsed = safeParse(r.bullets_json, null);\n    let narrative = '', bullets = [];\n    if (Array.isArray(parsed)) {\n      // Legacy v1: bullets_json was just the bullets array\n      bullets = parsed;\n    } else if (parsed && typeof parsed === 'object') {\n      narrative = typeof parsed.narrative === 'string' ? parsed.narrative : '';\n      bullets = Array.isArray(parsed.bullets) ? parsed.bullets : [];\n    }\n    return Object.assign({}, r, { narrative, bullets });\n  });\n}\nasync function dbInsertResearch(r) {\n  await echobraid.db.exec(\n    'INSERT INTO research(id, session_id, text, status, result, created_at, evidence) VALUES(?,?,?,?,?,?,?)',\n    [r.id, r.session_id, r.text, r.status, r.result || null, r.created_at, r.evidence || null]\n  );\n}\nasync function dbDeleteResearch(id) {\n  await echobraid.db.exec('DELETE FROM research WHERE id=?', [id]);\n}\n// Mutable column allowlists — prevent SQL injection via attacker-controlled\n// patch keys. All dbUpdate* functions interpolate column names into SQL\n// (parameterized placeholders work only for values, not identifiers), so any\n// key not in this list is silently dropped.\nconst RESEARCH_UPDATE_COLS = new Set(['session_id', 'text', 'status', 'result', 'evidence']);\nconst ACTION_UPDATE_COLS = new Set(['task', 'owner', 'due', 'evidence', 'done']);\nconst QUESTION_UPDATE_COLS = new Set(['text', 'evidence', 'resolved']);\nconst AGENT_RUN_UPDATE_COLS = new Set(['status', 'progress_json', 'result', 'error', 'updated_at']);\nfunction buildUpdateSql(table, whitelist, patch) {\n  const cols = Object.keys(patch).filter(c => whitelist.has(c));\n  if (!cols.length) return null;\n  const sets = cols.map(c => c + '=?').join(',');\n  const vals = cols.map(c => patch[c]);\n  return { sql: 'UPDATE ' + table + ' SET ' + sets + ' WHERE id=?', vals };\n}\nasync function dbUpdateResearch(id, patch) {\n  const q = buildUpdateSql('research', RESEARCH_UPDATE_COLS, patch);\n  if (!q) return;\n  await echobraid.db.exec(q.sql, [...q.vals, id]);\n}\nasync function dbLoadResearch(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM research WHERE session_id=? ORDER BY created_at ASC', [sessionId]);\n  appState.research = rows || [];\n}\nasync function dbInsertAction(a) {\n  await echobraid.db.exec(\n    'INSERT INTO actions(id, session_id, task, owner, due, evidence, done, created_at) VALUES(?,?,?,?,?,?,?,?)',\n    [a.id, a.session_id, a.task, a.owner || null, a.due || null, a.evidence || null, a.done ? 1 : 0, a.created_at]\n  );\n}\nasync function dbUpdateAction(id, patch) {\n  const q = buildUpdateSql('actions', ACTION_UPDATE_COLS, patch);\n  if (!q) return;\n  await echobraid.db.exec(q.sql, [...q.vals, id]);\n}\nasync function dbLoadActions(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM actions WHERE session_id=? ORDER BY created_at ASC', [sessionId]);\n  appState.actions = (rows || []).map(r => Object.assign({}, r, { done: !!r.done }));\n}\nasync function dbInsertQuestion(q) {\n  await echobraid.db.exec(\n    'INSERT INTO questions(id, session_id, text, evidence, resolved, created_at) VALUES(?,?,?,?,?,?)',\n    [q.id, q.session_id, q.text, q.evidence || null, q.resolved ? 1 : 0, q.created_at]\n  );\n}\nasync function dbUpdateQuestion(id, patch) {\n  const q = buildUpdateSql('questions', QUESTION_UPDATE_COLS, patch);\n  if (!q) return;\n  await echobraid.db.exec(q.sql, [...q.vals, id]);\n}\nasync function dbLoadQuestions(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM questions WHERE session_id=? ORDER BY created_at ASC', [sessionId]);\n  appState.questions = (rows || []).map(r => Object.assign({}, r, { resolved: !!r.resolved }));\n}\n\nasync function dbInsertMarker(m) {\n  await echobraid.db.exec(\n    'INSERT INTO markers(id, session_id, timestamp_ms, transcript_anchor, note, created_at) VALUES(?,?,?,?,?,?)',\n    [m.id, m.session_id, m.timestamp_ms, m.transcript_anchor || null, m.note || null, m.created_at]\n  );\n}\nasync function dbLoadMarkers(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM markers WHERE session_id=? ORDER BY timestamp_ms ASC', [sessionId]);\n  appState.markers = rows || [];\n}\nasync function dbInsertAgentMessage(m) {\n  await echobraid.db.exec(\n    'INSERT INTO agent_messages(id, session_id, role, content, source_type, source_id, created_at) VALUES(?,?,?,?,?,?,?)',\n    [m.id, m.session_id, m.role, m.content, m.source_type || null, m.source_id || null, m.created_at]\n  );\n}\nasync function dbLoadAgentMessages(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM agent_messages WHERE session_id=? ORDER BY created_at ASC', [sessionId]);\n  appState.agentMessages = rows || [];\n}\nasync function dbInsertAgentRun(r) {\n  await echobraid.db.exec(\n    'INSERT INTO agent_runs(id, session_id, source_type, source_id, status, progress_json, result, error, created_at, updated_at) VALUES(?,?,?,?,?,?,?,?,?,?)',\n    [r.id, r.session_id, r.source_type || null, r.source_id || null, r.status, JSON.stringify(r.progress || null), r.result || null, r.error || null, r.created_at, r.updated_at]\n  );\n}\nasync function dbUpdateAgentRun(id, patch) {\n  const q = buildUpdateSql('agent_runs', AGENT_RUN_UPDATE_COLS, patch);\n  if (!q) return;\n  await echobraid.db.exec(q.sql, [...q.vals, id]);\n}\nasync function dbLoadAgentRuns(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM agent_runs WHERE session_id=? ORDER BY created_at ASC', [sessionId]);\n  appState.agentRuns = (rows || []).map(r => Object.assign({}, r, { progress: safeParse(r.progress_json, null) }));\n  appState.agentProgress = {};\n  for (const r of appState.agentRuns) {\n    if (r.progress) appState.agentProgress[r.id] = r.progress;\n  }\n}\nasync function dbUpdateSessionDuration(id, duration, status) {\n  const nextStatus = status || 'paused';\n  const finalizedAt = nextStatus === 'ended' ? nowMs() : null;\n  if (nextStatus === 'ended') {\n    await echobraid.db.exec('UPDATE sessions SET duration_ms=?, status=?, finalized_at=? WHERE id=?', [duration, nextStatus, finalizedAt, id]);\n  } else {\n    await echobraid.db.exec('UPDATE sessions SET duration_ms=?, status=?, finalized_at=NULL WHERE id=?', [duration, nextStatus, id]);\n  }\n  const s = appState.sessions.find(x => x.id === id);\n  if (s) { s.duration_ms = duration; s.status = nextStatus; s.finalized_at = finalizedAt; }\n}\nasync function dbInsertAudioFile(f) {\n  await echobraid.db.exec(\n    'INSERT OR REPLACE INTO audio_files(id, session_id, path, name, mime, size_bytes, duration_ms, sample_rate, source, created_at, sha256) VALUES(?,?,?,?,?,?,?,?,?,?,?)',\n    [f.id, f.session_id, f.path, f.name, f.mime, f.size_bytes, f.duration_ms, f.sample_rate, f.source, f.created_at, f.sha256 || null]\n  );\n}\nasync function dbLoadAudioFiles(sessionId) {\n  const rows = await echobraid.db.query('SELECT * FROM audio_files WHERE session_id=? ORDER BY created_at ASC, name ASC', [sessionId]);\n  appState.audioFiles = rows || [];\n}\nasync function dbDeleteAudioFile(id) {\n  await echobraid.db.exec('DELETE FROM audio_files WHERE id=?', [id]);\n}\n\n/* ═══ AudioWorklet ═══ */\nconst WORKLET_SRC = `class PCMExtractor extends AudioWorkletProcessor {\n  process(inputs) {\n    const input = inputs[0];\n    if (input && input[0]) {\n      const buf = new Float32Array(input[0].length);\n      buf.set(input[0]);\n      this.port.postMessage(buf, [buf.buffer]);\n    }\n    return true;\n  }\n}\nregisterProcessor('pcm-extractor', PCMExtractor);`;\n\n/* ═══ Mic recording ═══ */\nasync function startRecording() {\n  clearWsReconnect();\n  if (appState.recording) return;\n  if (currentSessionFinalized()) {\n    appState.currentSessionId = null;\n    appState.segments = []; appState.summaries = []; appState.actions = []; appState.questions = []; appState.research = [];\n    appState.markers = []; appState.agentMessages = []; appState.agentRuns = []; appState.agentProgress = {};\n    appState.audioFiles = []; revokeAudioUrls();\n    renderSessions(); renderTranscript(); renderSummaries(); renderTasks(); renderAudioFiles();\n  }\n  if (quotaRemainingSeconds() === 0) {\n    toast('今日 ASR 用量已达 1 小时上限，请明天再试', 'error');\n    return;\n  }\n  log('mic', 'startRecording');\n  sentFrameCount = 0; sentByteCount = 0; pcmChunksRcvd = 0; recvMsgCount = 0;\n  appState.tearingDown = false;\n  try {\n    log('mic', 'requestPermission(\"microphone\") begin');\n    const rp = await (echobraid.requestPermission ? echobraid.requestPermission('microphone') : Promise.resolve());\n    log('mic', 'requestPermission result=', rp);\n  } catch (e) { log('mic', 'requestPermission THREW:', e && e.message || e); }\n  try {\n    log('mic', 'getUserMedia begin');\n    appState.mediaStream = await navigator.mediaDevices.getUserMedia({\n      // autoGainControl must be ON — xiaozhi's VAD needs consistent signal level\n      // to reliably detect speech boundaries. Without AGC quiet microphones\n      // never trigger an utterance commit.\n      audio: { channelCount: 1, echoCancellation: true, noiseSuppression: true, autoGainControl: true }\n    });\n    log('mic', 'getUserMedia OK tracks=' + appState.mediaStream.getTracks().length);\n  } catch (e) {\n    log('mic', 'getUserMedia FAIL name=' + (e && e.name) + ' msg=' + (e && e.message));\n    toast('麦克风获取失败：' + (e && (e.name + ' ' + e.message) || e), 'error');\n    setStatus('error', '麦克风失败：' + (e && (e.name + ': ' + e.message) || e));\n    return;\n  }\n  if (!appState.currentSessionId) { await dbCreateSession('mic'); log('mic', 'created session ' + appState.currentSessionId); }\n  const Ctx = window.AudioContext || window.webkitAudioContext;\n  try {\n    appState.audioCtx = new Ctx({ sampleRate: SAMPLE_RATE });\n    log('mic', 'AudioContext ok sampleRate=' + appState.audioCtx.sampleRate);\n  } catch (e) {\n    log('mic', 'AudioContext FAIL', e && e.message || e);\n    setStatus('error', 'AudioContext 失败：' + (e && e.message || e));\n    try { appState.mediaStream.getTracks().forEach(t => t.stop()); } catch {}\n    return;\n  }\n  try {\n    const url = URL.createObjectURL(new Blob([WORKLET_SRC], { type: 'application/javascript' }));\n    await appState.audioCtx.audioWorklet.addModule(url);\n    URL.revokeObjectURL(url);\n    log('mic', 'worklet module added');\n  } catch (e) {\n    log('mic', 'worklet addModule FAIL', e && e.message || e);\n    setStatus('error', 'Worklet 加载失败：' + (e && e.message || e));\n    // Release mic track + AudioContext we already acquired so we don't leak\n    // an open mic after a worklet failure. Idempotent teardown.\n    await teardownAudioWs();\n    return;\n  }\n  const src = appState.audioCtx.createMediaStreamSource(appState.mediaStream);\n  appState.workletNode = new AudioWorkletNode(appState.audioCtx, 'pcm-extractor');\n  appState.workletNode.port.onmessage = onPcmChunk;\n  src.connect(appState.workletNode);\n  const sink = appState.audioCtx.createGain();\n  sink.gain.value = 0;\n  appState.workletNode.connect(sink);\n  sink.connect(appState.audioCtx.destination);\n  log('mic', 'audio graph wired, opening ws');\n\n  await openWs();\n  if (!appState.wsConnected) {\n    // WS failed — roll back the audio graph so we don't leak mic track / audio context.\n    await teardownAudioWs();\n    return;\n  }\n  await beginAudioArchive('mic');\n  appState.recording = true;\n  renderAudioFiles();\n  appState.recordStartMs = nowMs();\n  appState.pcmBufferFill = 0;\n  appState.lastSummaryAt = nowMs();\n  appState.lastSummaryCharCount = 0;\n  appState.summaryTimerHandle = setInterval(maybeRunSummary, 5000);\n  appState.timerHandle = setInterval(tickTimer, 500);\n  updateMicUI();\n}\n\n/* Idempotent teardown — safe to call regardless of recording/wsConnected\n   state. Used both by pauseRecording and as the stopSession safety net so\n   even a partial-init failure (WS opened but recording=false, or mic acquired\n   but WS errored) doesn't leak a mic track or AudioContext. */\nasync function teardownAudioWs() {\n  // Reentry guard — stopSession → pauseRecording → teardownAudioWs, then\n  // stopSession calls teardownAudioWs again as safety net. Second call is\n  // a no-op so we don't double-close an already-closed AudioContext (which\n  // warns in some browsers even under try/catch).\n  // Flag lives on appState so it's reset every new recording lifecycle (see\n  // startRecording) — prevents a stuck true-value from stranding teardown\n  // if an exception escaped the finally.\n  if (appState.tearingDown) return;\n  appState.tearingDown = true;\n  try {\n    clearWsReconnect();\n    clearInterval(appState.timerHandle); appState.timerHandle = null;\n    clearInterval(appState.summaryTimerHandle); appState.summaryTimerHandle = null;\n    try { appState.workletNode && appState.workletNode.disconnect(); } catch {}\n    try { appState.audioCtx && (await appState.audioCtx.close()); } catch {}\n    try { appState.mediaStream && appState.mediaStream.getTracks().forEach(t => t.stop()); } catch {}\n    appState.workletNode = null; appState.audioCtx = null; appState.mediaStream = null;\n    try { await echobraid.ws.close(WS_CHANNEL); } catch {}\n    appState.wsConnected = false;\n    appState.recording = false;\n    appState.pcmBufferFill = 0;\n  } finally {\n    appState.tearingDown = false;\n  }\n}\n\n/* Pause: flush any pending audio so the server can finalize the last segment,\n   then tear down mic / worklet / ws. xiaozhi has no end-of-session message —\n   the server detects silence (default 960ms) and emits the last utterance\n   on its own. We keep currentSessionId so the next click resumes. */\nasync function pauseRecording() {\n  if (!appState.recording) return;\n  log('mic', 'pauseRecording');\n  appState.recording = false;\n  clearInterval(appState.timerHandle); appState.timerHandle = null;\n  clearInterval(appState.summaryTimerHandle); appState.summaryTimerHandle = null;\n  try {\n    if (appState.pcmBufferFill > 0) {\n      const tail = appState.pcmBuffer.slice(0, appState.pcmBufferFill);\n      await sendFrame(tail);\n    }\n  } catch {}\n  await waitSendQueueIdle();\n  appState.pcmBufferFill = 0;\n  // Give xiaozhi ~1.2s to flush trailing audio through VAD → final utterance\n  // before closing the socket. 960ms is the documented silence threshold.\n  await new Promise(r => setTimeout(r, 1200));\n  await teardownAudioWs();\n  if (appState.currentSessionId) {\n    const dur = nowMs() - appState.recordStartMs;\n    await dbUpdateSessionDuration(appState.currentSessionId, dur, 'paused');\n  }\n  updateMicUI();\n  renderSessions();\n}\n\n/* Stop: fully end the current session. Pauses first (guaranteeing the last\n   interim lands as a segment), then clears currentSessionId so a fresh\n   start would create a new session. Also triggers a final summary pass. */\nasync function stopSession() {\n  log('mic', 'stopSession');\n  if (appState.recording) await pauseRecording();\n  // Safety net even if pauseRecording was skipped (e.g. WS errored before\n  // recording=true). Idempotent — no-op if already torn down.\n  await teardownAudioWs();\n  if (appState.currentSessionId) {\n    await runSummary(true);\n    const endedSessionId = appState.currentSessionId;\n    const s = appState.sessions.find(x => x.id === endedSessionId);\n    const dur = Number(s && s.duration_ms) || (appState.recordStartMs ? nowMs() - appState.recordStartMs : 0);\n    await dbUpdateSessionDuration(endedSessionId, dur, 'ended');\n    await finalizeAudioArchive();\n    await dbLoadSessions();\n    clearCurrentSessionState();\n  }\n  renderSessions();\n  renderTranscript();\n  renderSummaries();\n  renderTasks();\n  renderAudioFiles();\n  renderHome();\n  updateMicUI();\n}\n\n\n/* Back-compat shim: some call-sites (file upload, ws:close handler) still\n   call stopRecording(). Route them to pauseRecording which now holds the\n   teardown logic but leaves currentSessionId so a manual \"stop\" can finalize. */\nasync function stopRecording() {\n  return pauseRecording();\n}\n\nlet pcmChunksRcvd = 0;\nfunction onPcmChunk(ev) {\n  pcmChunksRcvd++;\n  if (pcmChunksRcvd === 1) log('mic', 'first PCM chunk from worklet, len=' + ev.data.length);\n  const float = ev.data;\n  for (let i = 0; i < float.length; i++) {\n    // xiaozhi wants raw Float32 @ 16kHz — no quantization, just clamp + copy.\n    appState.pcmBuffer[appState.pcmBufferFill++] = Math.max(-1, Math.min(1, float[i]));\n    if (appState.pcmBufferFill >= FRAME_SAMPLES) {\n      const frame = appState.pcmBuffer.slice(0, FRAME_SAMPLES);\n      appState.pcmBufferFill = 0;\n      sendFrame(frame);\n    }\n  }\n}\n/* Serialized send queue — avoid stacking awaits if the bridge is slow.\n   Bounded to 50 frames (~10s of audio); oldest dropped on overflow.\n   Send each chunk as raw Float32 LE PCM bytes (xiaozhi wire format). */\nconst sendQueue = [];\nconst SEND_QUEUE_MAX = 50;\nlet sendInFlight = false;\nlet sentFrameCount = 0;\nlet sentByteCount = 0;\nlet recvMsgCount = 0;\nfunction updateLiveStatus() {\n  if (appState.recording && appState.wsConnected) {\n    setStatus('connected', '正在记录');\n  }\n}\nasync function sendFrame(float32) {\n  if (!appState.wsConnected || !float32 || !float32.length) return;\n  if (sendQueue.length >= SEND_QUEUE_MAX) sendQueue.shift();\n  const bytes = new Uint8Array(float32.buffer.slice(float32.byteOffset, float32.byteOffset + float32.byteLength));\n  sendQueue.push(bytes.buffer);\n  if (sendInFlight) return;\n  sendInFlight = true;\n  try {\n    while (sendQueue.length) {\n      const buf = sendQueue.shift();\n      try {\n        await echobraid.ws.send(WS_CHANNEL, buf);\n        sentFrameCount++;\n        sentByteCount += buf.byteLength;\n        appendAudioFrameBuffer(buf);\n        if (sentFrameCount === 1) log('audio', 'first frame sent (' + buf.byteLength + 'B)');\n        else if (sentFrameCount % 10 === 0) log('audio', sentFrameCount + ' frames / ' + sentByteCount + 'B total');\n        if (sentFrameCount % 5 === 0) updateLiveStatus();\n      } catch (e) {\n        log('audio', 'send FAIL', e && e.message || e);\n      }\n    }\n  } finally { sendInFlight = false; }\n}\n\n/* ═══ WebSocket ═══ */\nfunction clearWsReconnect() {\n  if (appState.wsReconnectTimer) {\n    clearTimeout(appState.wsReconnectTimer);\n    appState.wsReconnectTimer = null;\n  }\n  appState.wsReconnectAttempts = 0;\n}\n\nfunction scheduleWsReconnect(reason) {\n  if (!appState.recording || appState.tearingDown || appState.wsReconnectTimer) return;\n  const delay = Math.min(5000, 600 * Math.pow(1.7, appState.wsReconnectAttempts++));\n  log('ws', 'schedule reconnect in ' + Math.round(delay) + 'ms reason=' + reason);\n  appState.wsReconnectTimer = setTimeout(async () => {\n    appState.wsReconnectTimer = null;\n    if (!appState.recording || appState.tearingDown || appState.wsConnected) return;\n    setStatus('connecting', '转写重连中…');\n    await openWs();\n    if (!appState.wsConnected && appState.recording && !appState.tearingDown) {\n      scheduleWsReconnect('retry_failed');\n    }\n  }, delay);\n}\n\nasync function openWs() {\n  setStatus('connecting', '连接转写服务…');\n  let url;\n  try {\n    url = await buildSignedWsUrl();\n  } catch (e) {\n    setStatus('error', '签发失败：' + (e && e.message ? e.message : e));\n    return;\n  }\n  log('ws', 'openWs begin url=' + url.replace(/([?&]sig=)[^&]+/, '$1…'));\n  let result;\n  try {\n    result = await echobraid.ws.connect(WS_CHANNEL, { url });\n    log('ws', 'connect result=', result);\n  } catch (e) {\n    log('ws', 'connect THREW', e && e.message || e);\n    setStatus('error', '连接异常：' + (e && e.message ? e.message : e));\n    return;\n  }\n  if (!result || !result.connected) {\n    const code = result && (result.__error || result.error) || '';\n    const msg = (result && result.message) || '';\n    log('ws', 'connect FAIL code=' + code + ' msg=' + msg);\n    setStatus('error', '连接失败：' + (code ? '[' + code + '] ' : '') + (msg || '未知'));\n    return;\n  }\n  appState.wsConnected = true;\n  clearWsReconnect();\n  setStatus('connected', '已连接');\n  log('ws', 'CONNECTED, ready to stream audio');\n  // xiaozhi has no handshake — first binary frame opens the recognition session.\n}\n\nfunction onWsEvent(ev) {\n  const d = ev.detail;\n  if (!d || !d.data) return;\n  const channel = d.data.channel;\n  if (channel !== WS_CHANNEL && channel !== WS_QUOTA_CHANNEL) return;\n  if (d.event === 'ws:message') {\n    recvMsgCount++;\n    log('ws:msg', 'channel=' + channel + ' type=' + d.data.type + ' len=' + (d.data.data ? (typeof d.data.data === 'string' ? d.data.data.length : d.data.data.byteLength) : 0));\n    if (d.data.type === 'text' && typeof d.data.data === 'string') {\n      if (!maybeHandleQuotaMessage(d.data.data, channel) && channel === WS_CHANNEL) {\n        handleServerMessage(d.data.data);\n      }\n    } else if (d.data.type === 'binary') {\n      log('ws:msg', 'UNEXPECTED binary frame (server should send text JSON)');\n    }\n    if (channel === WS_CHANNEL) updateLiveStatus();\n  } else if (d.event === 'ws:error') {\n    log('ws', 'error:', d.data.error);\n    if (channel === WS_CHANNEL) {\n      appState.wsConnected = false;\n      if (appState.tearingDown) return;\n      if (appState.recording) {\n        setStatus('connecting', '转写重连中…');\n        scheduleWsReconnect('error ' + (d.data.error || 'unknown'));\n      } else {\n        setStatus('error', 'WS 错误：' + (d.data.error || 'unknown'));\n      }\n    }\n  } else if (d.event === 'ws:close') {\n    const code = Number(d.data.code) || 0;\n    const reason = d.data.reason || '';\n    log('ws', 'close channel=' + channel + ' code=' + code + ' reason=' + reason);\n    if (channel === WS_CHANNEL) {\n      appState.wsConnected = false;\n      if (appState.tearingDown) return;\n      if (appState.recording) {\n        if (code === 4429 || /quota/i.test(reason)) {\n          setStatus('error', '今日额度已用完');\n          pauseRecording();\n        } else {\n          setStatus('connecting', '转写重连中…');\n          scheduleWsReconnect('close ' + code + ' ' + reason);\n        }\n      }\n    }\n  } else if (d.event === 'ws:open') {\n    log('ws', 'open event received channel=' + channel);\n  }\n}\n\n// Hard upper bounds on what we accept from xiaozhi. The endpoint has no auth,\n// so any actor able to MITM or take over the server can push arbitrary JSON.\n// content flows into the LLM summary prompt → hostile content could drive a\n// prompt-injection attack on EchoAgent. Caps defeat the easy shape of that:\n// - MAX_UTTERANCE_CHARS keeps DB + prompt tokens bounded\n// - MAX_SPEAKER_CHARS + regex ensures speaker is at most \"说话人99999\"-shaped\nconst MAX_UTTERANCE_CHARS = 2000;\nconst MAX_SPEAKER_CHARS = 32;\nconst SPEAKER_PATTERN = /^[\\u4e00-\\u9fa5A-Za-z_][\\u4e00-\\u9fa5A-Za-z0-9_ -]{0,31}$/;\n\nfunction handleServerMessage(raw) {\n  let msg;\n  try { msg = JSON.parse(raw); } catch {\n    log('ws:msg', 'JSON parse FAIL raw=', raw.slice(0, 200));\n    return;\n  }\n  if (!msg || typeof msg !== 'object') return;\n  if (msg.type === 'quota') {\n    maybeHandleQuotaMessage(raw, WS_CHANNEL);\n    return;\n  }\n  // If stopSession already cleared currentSessionId, xiaozhi may still emit\n  // one final utterance during the 1.2s drain window. Dropping it is better\n  // than writing a row with null session_id that later loads can't find.\n  if (!appState.currentSessionId) return;\n  // xiaozhi wire protocol: one JSON {speaker, content} per committed utterance.\n  // No partials, no session final — each message is a complete segment.\n  let content = typeof msg.content === 'string' ? msg.content.trim() : '';\n  let speaker = typeof msg.speaker === 'string' ? msg.speaker.trim() : '';\n  // Length + shape caps (see MAX_* constants above).\n  if (content.length > MAX_UTTERANCE_CHARS) content = content.slice(0, MAX_UTTERANCE_CHARS);\n  if (speaker.length > MAX_SPEAKER_CHARS) speaker = speaker.slice(0, MAX_SPEAKER_CHARS);\n  if (speaker && !SPEAKER_PATTERN.test(speaker)) {\n    log('ws:msg', 'invalid speaker shape, dropping label', JSON.stringify(speaker));\n    speaker = '';\n  }\n  log('srv', 'utterance', 'speaker=' + speaker, 'text=', content.slice(0, 80));\n  if (!content) return;\n  const last = appState.segments[appState.segments.length - 1];\n  if (last && last.text === content && last.speaker === speaker) return; // dedupe\n  // Timing note: xiaozhi doesn't return audio-clock offsets, so we synthesize\n  // start/end from client wall clock relative to recordStartMs. This is\n  // \"good enough\" for summary window slicing (based on end_ms > windowStart)\n  // but not precise to the audio ms. Two rapid utterances share the nominal\n  // start = prior end; acceptable Phase 2 limit.\n  const endMs = appState.recording ? (nowMs() - appState.recordStartMs) : (appState.lastFinalEndMs || 0);\n  const startMs = appState.lastFinalEndMs || 0;\n  const seg = {\n    session_id: appState.currentSessionId,\n    start_ms: startMs,\n    end_ms: endMs,\n    text: content,\n    is_definite: true,\n    speaker: speaker || null,\n  };\n  appState.segments.push(seg);\n  appState.lastFinalEndMs = endMs;\n  dbInsertSegment(seg).catch(e => reportDbErr('insert_segment', e));\n  renderTranscript();\n}\n\n/* ═══ Summary pump ═══ */\nasync function maybeRunSummary() {\n  if (appState.summaryInFlight) return;\n  const now = nowMs();\n  if (appState.summaryRetryAfterMs && now < appState.summaryRetryAfterMs) return;\n  const charCount = appState.segments.reduce((n, s) => n + ((s.text && s.text.length) || 0), 0);\n  const newChars = charCount - appState.lastSummaryCharCount;\n  if (newChars >= SUMMARY_CHAR_THRESHOLD ||\n      (now - appState.lastSummaryAt >= SUMMARY_INTERVAL_MS && newChars > 20)) {\n    await runSummary(false);\n  }\n}\n\n/* Collect the last ~20 bullet texts across all prior summaries so the model\n   can dedupe — this is the prefix-prompt accumulator pattern (arxiv 2510.06677)\n   that cuts chunk-summary redundancy in live transcription products. */\nfunction collectPrevBullets() {\n  const out = [];\n  for (const sm of appState.summaries) {\n    for (const b of (sm.bullets || [])) {\n      const t = typeof b === 'string' ? b : (b && b.text) || '';\n      if (t) out.push(t);\n    }\n  }\n  return out.slice(-20);\n}\n\nfunction collectPrevResearch() {\n  return appState.research.map(r => r.text || '').filter(Boolean).slice(-20);\n}\n\n/* Coerce each summary entry into {text, evidence, ...} shape. Models sometimes\n   still return bare strings despite the schema; normalize so render + storage\n   paths don't have to branch. */\nfunction normEntries(arr, isAction) {\n  if (!Array.isArray(arr)) return [];\n  return arr.map(x => {\n    if (typeof x === 'string') return isAction ? { task: x } : { text: x };\n    if (!x || typeof x !== 'object') return null;\n    if (isAction) {\n      return {\n        task: String(x.task || x.text || '').trim(),\n        owner: x.owner && typeof x.owner === 'string' ? x.owner : null,\n        due: x.due && typeof x.due === 'string' ? x.due : null,\n        evidence: typeof x.evidence === 'string' ? x.evidence : '',\n      };\n    }\n    return {\n      text: String(x.text || '').trim(),\n      evidence: typeof x.evidence === 'string' ? x.evidence : '',\n    };\n  }).filter(x => x && (x.text || x.task));\n}\n\nasync function runSummary(isFinal) {\n  if (appState.summaryInFlight) return;\n  if (appState.summaryRetryAfterMs && nowMs() < appState.summaryRetryAfterMs) return;\n  const segs = appState.segments;\n  if (!segs.length) return;\n  const last = appState.summaries[appState.summaries.length - 1];\n  const windowStart = last ? last.window_end_ms : 0;\n  const sliced = segs.filter(s => s.end_ms > windowStart);\n  if (!sliced.length) return;\n  const windowEnd = sliced[sliced.length - 1].end_ms;\n  // Speaker-aware transcript: each utterance becomes \"说话人N: ...\". The\n  // summary model can now attribute decisions/todos to the right person\n  // (\"说话人1 承诺周五交初稿\") instead of falling back to \"有人\".\n  const text = sliced.map(s => {\n    const spk = s.speaker ? (s.speaker + '：') : '';\n    return spk + (s.text || '');\n  }).join('\\n');\n  if (text.length < 20 && !isFinal) return;\n  appState.summaryInFlight = true;\n\n  const systemPrompt = [\n    '你是中文会议速记助手。输入是会议实时转写的一段新片段，**每句前带\"说话人N：\"标识**（N 由声纹聚类得到，不是真实姓名）。',\n    '',\n    '你的产出分两层：',\n    '【片段层】narrative —— 只输出一段连续中文总结，描述\"这段在讨论什么\"。把决定、分配给人的待办、悬而未决的问题都融入这段文字里，不要列条目。',\n    '【会议层】research —— **很谨慎地、很少地**提取真正适合让 AI 研究助手（EchoAgent）展开调研的事项（比如查 GitHub 项目、对比竞品、查法规/数据、梳理开源资料）。这不是给人干的待办，也不是当面能问清的问题，**也不是会议里一带而过的 reference**。',\n    '',\n    '规则（按顺序执行）：',\n    '1. narrative 是 1 段中文自然段落，概括本片段。把重要的决定、待办、提问都叙述进来（不要另开字段，不要项目符号，不要编号）。',\n    '2. bullets 必须始终返回 []。摘要界面只显示 narrative；不要把总结拆成多条。',\n    '3. **research 默认 []，极谨慎地放行**。一整场会议（通常 30-90 分钟）全程累计的 research **典型数量是 0-3 条**，绝不是每段都出 research。要放行必须同时满足：(a) 这个事项**明显需要外部资料/工具/数据**才能回答（不是靠讨论能定下来）；(b) 片段里**反复讨论或明确提出\"谁去查一下\"**，不是一带而过；(c) 与 <已有研究> 无语义重复。只要有一条不满足 → research=[]。',\n    '4. **大部分片段 research=[] 是正常的、甚至是期望的**。宁可遗漏，绝不硬凑。',\n    '5. research 与 <已有研究> 语义重复则丢弃。同一主题在本场会议中**最多一条**。',\n    '6. 忽略语气词（嗯/啊/那个/就是/然后），但保留中英混用术语原样（GitHub / Agent / PR 等）。',\n    '7. **使用\"说话人N\"标识**叙述谁说了什么 / 谁承诺了什么 / 谁提出了问题（例如\"说话人1 承诺周五前交初稿\"）。只有上下文能明确推断出真实姓名时才可替换，不得虚构姓名。无标识时用\"有人\"或\"发言者\"。',\n    '8. 证据不足（片段 <30 字或全是寒暄）→ narrative 返回空串 \"\"，其他字段返回空数组 []。',\n    '9. research 每条必须带 evidence 原文锚点（6-15 字逐字截取片段原文，**不含\"说话人N：\"前缀**，不得改写）。',\n    '10. 严格输出一个 JSON 对象，无 markdown、无代码块围栏、无解释文字。',\n    '',\n    'Schema：',\n    '{',\n    '  \"narrative\": \"一段连续中文总结（含决定/待办/提问等自然叙述）\",',\n    '  \"bullets\": [],',\n    '  \"research\": [{\"text\":\"适合 EchoAgent 调研的事项\",\"evidence\":\"原文片段\"}]',\n    '}',\n    '',\n    '上限：bullets 必须为 []，**research ≤ 1（绝大多数片段为 0）**。',\n  ].join('\\n');\n\n  const prevSummaries = appState.summaries\n    .map(sm => sm.narrative || '')\n    .filter(Boolean)\n    .slice(-8);\n  const prevResearch = collectPrevResearch();\n  const userContent = [\n    '<已有摘要>',\n    JSON.stringify(prevSummaries, null, 0),\n    '</已有摘要>',\n    '',\n    '<已有研究>',\n    JSON.stringify(prevResearch, null, 0),\n    '</已有研究>',\n    '',\n    '<本次片段>',\n    text,\n    '</本次片段>',\n  ].join('\\n');\n\n  let reply;\n  try {\n    reply = await echobraid.invoke('llm:complete', {\n      messages: [\n        { role: 'system', content: systemPrompt + '\\n\\n重要：这是应用内自动总结调用。禁止使用工具，禁止解释过程，禁止 markdown，只返回一个符合 schema 的 JSON 对象。' },\n        { role: 'user', content: userContent },\n      ],\n      maxTokens: 800,\n    });\n  } catch (e) {\n    const msg = e && (e.message || e.__error) || String(e);\n    if (/not configured/i.test(msg)) {\n      appState.summaryRetryAfterMs = nowMs() + 15000;\n      showSummaryError('总结暂不可用：EchoAgent 还没配置或仍在启动，稍后会自动重试');\n    } else {\n      appState.summaryRetryAfterMs = nowMs() + 5000;\n      showSummaryError('总结失败：' + msg);\n    }\n    appState.summaryInFlight = false;\n    return;\n  }\n  const replyText = (reply && (reply.content || reply.text)) || '';\n  log('summary', 'llm reply len=' + replyText.length);\n  const parsed = parseSummaryReply(replyText) || fallbackSummaryReply(replyText);\n  if (!parsed) {\n    log('summary', 'parse FAIL raw=', replyText.slice(0, 200));\n    showSummaryError('总结失败：模型返回为空');\n    appState.summaryInFlight = false;\n    return;\n  }\n\n  // Summary chunks are rendered as plain narrative paragraphs.\n  // Actions / questions / research get promoted to the global deduped tables\n  // so the right-hand panel surfaces one clean list instead of fragmenting\n  // actionables across every 60s window.\n  const sm = {\n    session_id: appState.currentSessionId,\n    window_start_ms: windowStart,\n    window_end_ms: windowEnd,\n    narrative: typeof parsed.narrative === 'string' ? parsed.narrative.trim() : '',\n    bullets: [],\n  };\n  appState.summaries.push(sm);\n  await dbInsertSummary(sm);\n\n  // Only research items are surfaced as global tasks (the ones actually\n  // suited for EchoAgent to work on). Narrative already describes decisions,\n  // assigned todos and open questions in natural language.\n  // MAX_RESEARCH_PER_SESSION hoisted to module scope (see top of file).\n  const normText = (s) => (s || '').trim().replace(/\\s+/g, '').toLowerCase();\n  const existingKeys = new Set(appState.research.map(r => normText(r.text)));\n  // Count research for the CURRENT session only. appState.research can hold\n  // items loaded from a switched-to historical session via dbLoadResearch;\n  // capping against that total would spuriously block new items in the\n  // newly-recorded session.\n  let currentSessionResearchCount = appState.research\n    .filter(r => r.session_id === appState.currentSessionId).length;\n  let droppedOverCap = 0;\n  for (const item of normEntries(parsed.research, false)) {\n    if (currentSessionResearchCount >= MAX_RESEARCH_PER_SESSION) {\n      droppedOverCap++;\n      continue;\n    }\n    const key = normText(item.text);\n    if (!key || existingKeys.has(key)) continue;\n    existingKeys.add(key);\n    const r = {\n      id: uuid(),\n      session_id: appState.currentSessionId,\n      text: item.text,\n      evidence: item.evidence || null,\n      status: 'draft',\n      result: null,\n      created_at: nowMs(),\n    };\n    appState.research.push(r);\n    currentSessionResearchCount++;\n    await dbInsertResearch(r);\n  }\n  if (droppedOverCap > 0) {\n    log('summary', 'research_dropped_over_cap count=' + droppedOverCap + ' cap=' + MAX_RESEARCH_PER_SESSION);\n  }\n  appState.lastSummaryAt = nowMs();\n  appState.lastSummaryCharCount = segs.reduce((n, s) => n + ((s.text && s.text.length) || 0), 0);\n  appState.summaryRetryAfterMs = 0;\n  appState.summaryInFlight = false;\n  renderSummaries();\n  renderTasks();\n}\n\nfunction showSummaryError(message) {\n  toast(message, 'error');\n  const body = document.getElementById('summary-body');\n  if (body) body.innerHTML = '<div class=\"empty\">' + escapeHtml(message) + '</div>';\n}\n\nfunction parseSummaryReply(txt) {\n  if (!txt) return null;\n  const m = txt.match(/\\{[\\s\\S]*\\}/);\n  if (!m) return null;\n  try { return JSON.parse(m[0]); } catch { return null; }\n}\nfunction fallbackSummaryReply(txt) {\n  const cleaned = String(txt || '')\n    .replace(/^\\s*```(?:json)?/i, '')\n    .replace(/```\\s*$/i, '')\n    .trim();\n  if (!cleaned) return null;\n  return { narrative: cleaned.slice(0, 500), bullets: [], research: [] };\n}\n\n/* ═══ Research dispatch ═══ */\n/* Builds a rich, context-stuffed prompt for the research agent instead of\n   sending only the bare one-line text. The extra context helps EchoAgent\n   understand *why* this item matters (meeting arc + original quote + adjacent\n   transcript), what to produce, and what constraints apply. */\nfunction buildResearchPrompt(r) {\n  const session = appState.sessions.find(s => s.id === r.session_id);\n  const sessionTitle = (session && session.title) || '未命名会议';\n  const durationMin = session ? Math.round((session.duration_ms || (nowMs() - appState.recordStartMs)) / 60000) : 0;\n  const segmentCount = appState.segments.length;\n\n  // Meeting arc: the last up to 3 narratives give the agent the broad flow\n  const recentNarratives = appState.summaries\n    .map(sm => sm.narrative || '')\n    .filter(Boolean)\n    .slice(-3);\n  const arcBlock = recentNarratives.length\n    ? recentNarratives.map((n, i) => '  ' + (i + 1) + '. ' + n).join('\\n')\n    : '  （会议脉络信息不足）';\n\n  // Quote context: find the segment matching the evidence anchor and grab a\n  // ±3 sentence window around it so the agent sees what was said just before\n  // and after the item came up.\n  const ev = r.evidence || '';\n  let quoteBlock = '';\n  if (ev && appState.segments.length) {\n    const idx = appState.segments.findIndex(s => (s.text || '').includes(ev));\n    if (idx >= 0) {\n      const start = Math.max(0, idx - 3);\n      const end = Math.min(appState.segments.length, idx + 4);\n      const lines = [];\n      for (let i = start; i < end; i++) {\n        const s = appState.segments[i];\n        const marker = i === idx ? '  ★ ' : '    ';\n        lines.push(marker + (s.text || ''));\n      }\n      quoteBlock = lines.join('\\n');\n    } else {\n      quoteBlock = '  （未能匹配 evidence 原文）evidence: ' + ev;\n    }\n  } else if (ev) {\n    quoteBlock = '  （无转写上下文可用）evidence: ' + ev;\n  } else {\n    quoteBlock = '  （无引用上下文）';\n  }\n\n  return [\n    '# 任务类型',\n    '会议研究调查（由会议中的参会人提出，需要你代为调研并给出书面结论）。',\n    '',\n    '# 会议基本信息',\n    '- 会议标题：' + sessionTitle,\n    '- 会议进行时长：约 ' + durationMin + ' 分钟',\n    '- 已确认转写分句数：' + segmentCount,\n    '',\n    '# 会议最近的讨论脉络（按时间排序）',\n    arcBlock,\n    '',\n    '# 研究事项在原始转写里的上下文（★ 是触发本事项的那句）',\n    quoteBlock,\n    '',\n    '# 待调研的具体事项',\n    r.text,\n    '',\n    '# 产出要求',\n    '- 首行：一句话结论（不超过 40 字），直接回答或定性这个事项',\n    '- 然后 ≤6 条 bullets，包含：关键事实 / 可查证的数据 / 建议的信息来源 / 下一步行动',\n    '- 若必须引用外部资料，注明出处/链接；无法访问时明确标注\"待人工查证\"并说明缺什么',\n    '- 全程中文；保留中英混用术语原样（GitHub / Agent / PR 等）',\n    '- 不要重复\"任务背景\"里已说过的会议脉络；直接展开研究结论',\n    '- 不要输出寒暄或解释你在做什么，直接给产出',\n  ].join('\\n');\n}\n\nfunction setResearchProgress(id, phase, label, detail) {\n  appState.dispatchProgress[id] = { phase, label, detail: detail || '', updatedAt: nowMs() };\n  renderTasks();\n}\n\nfunction describeResearchEvent(event) {\n  const type = event && event.type;\n  if (type === 'run_started') return { phase: 'context', label: '已读取上下文', detail: 'EchoAgent 已接收会议材料' };\n  if (type === 'tool_call') {\n    const name = String(event.name || '工具');\n    if (/read|list|search_files|app_|session_status/.test(name)) return { phase: 'context', label: '已读取上下文', detail: name };\n    if (/web_search|fetch_url|browser|probe/.test(name)) return { phase: 'researching', label: '正在研究', detail: name };\n    return { phase: 'researching', label: '正在研究', detail: name };\n  }\n  if (type === 'delta') return { phase: 'generating', label: '正在生成结论', detail: '' };\n  if (type === 'usage_update') return { phase: 'generating', label: '正在生成结论', detail: '已生成 ' + (event.outputTokens || 0) + ' tokens' };\n  if (type === 'run_ended') return { phase: 'done', label: '完成', detail: '' };\n  if (type === 'error') return { phase: 'failed', label: '失败可重试', detail: event.error || '' };\n  return null;\n}\n\nfunction currentRecordMs() {\n  if (!appState.recordStartMs) return 0;\n  return Math.max(0, nowMs() - appState.recordStartMs);\n}\nfunction isTypingTarget(target) {\n  if (!target || !target.closest) return false;\n  return !!target.closest('input, textarea, select, button, [contenteditable=\"true\"], .agent-input');\n}\nfunction markerAnchorAt(timestampMs) {\n  if (!appState.segments.length) return '';\n  let best = null;\n  let bestDist = Infinity;\n  for (const s of appState.segments) {\n    const start = Number(s.start_ms) || 0;\n    const end = Number(s.end_ms) || start;\n    const inside = timestampMs >= start && timestampMs <= end;\n    const dist = inside ? 0 : Math.min(Math.abs(timestampMs - start), Math.abs(timestampMs - end));\n    if (dist < bestDist) { best = s; bestDist = dist; }\n  }\n  if (!best) return '';\n  const speaker = best.speaker ? best.speaker + '：' : '';\n  return speaker + (best.text || '').slice(0, 180);\n}\nasync function addAgentMessage(role, content, sourceType, sourceId) {\n  if (!appState.currentSessionId || !String(content || '').trim()) return null;\n  const msg = {\n    id: uuid(),\n    session_id: appState.currentSessionId,\n    role,\n    content: String(content || '').trim(),\n    source_type: sourceType || null,\n    source_id: sourceId || null,\n    created_at: nowMs(),\n  };\n  appState.agentMessages.push(msg);\n  try { await dbInsertAgentMessage(msg); } catch {}\n  renderTasks();\n  return msg;\n}\nasync function addMarkerFromKeyboard() {\n  if (!appState.recording || !appState.currentSessionId) return;\n  const marker = {\n    id: uuid(),\n    session_id: appState.currentSessionId,\n    timestamp_ms: currentRecordMs(),\n    transcript_anchor: markerAnchorAt(currentRecordMs()),\n    note: '',\n    created_at: nowMs(),\n  };\n  appState.markers.push(marker);\n  try { await dbInsertMarker(marker); } catch {}\n  await addAgentMessage('system', '已标记 ' + fmtDuration(marker.timestamp_ms) + ' 附近为重点' + (marker.transcript_anchor ? '：' + marker.transcript_anchor : ''), 'marker', marker.id);\n  renderTranscript();\n  toast('已打点：重点 ' + fmtDuration(marker.timestamp_ms));\n}\nfunction getNearbyTranscript(timestampMs, radius) {\n  if (!appState.segments.length) return [];\n  let idx = appState.segments.findIndex(s => timestampMs >= (Number(s.start_ms) || 0) && timestampMs <= (Number(s.end_ms) || 0));\n  if (idx < 0) {\n    let bestDist = Infinity;\n    appState.segments.forEach((s, i) => {\n      const dist = Math.abs((Number(s.start_ms) || 0) - timestampMs);\n      if (dist < bestDist) { bestDist = dist; idx = i; }\n    });\n  }\n  const start = Math.max(0, idx - radius);\n  const end = Math.min(appState.segments.length, idx + radius + 1);\n  return appState.segments.slice(start, end);\n}\nfunction formatTranscriptLines(segs) {\n  if (!segs || !segs.length) return '（暂无逐字稿）';\n  return segs.map(s => '[' + fmtDuration(s.start_ms || 0) + '] ' + (s.speaker ? s.speaker + '：' : '') + (s.text || '')).join('\\n');\n}\nfunction buildEchoRecAgentPrompt(options) {\n  const session = appState.sessions.find(s => s.id === appState.currentSessionId) || {};\n  const request = String(options && options.text || '').trim();\n  const sourceType = options && options.sourceType || 'manual';\n  const sourceId = options && options.sourceId || '';\n  const summaries = appState.summaries.map(sm => sm.narrative || '').filter(Boolean).slice(-4);\n  const markers = appState.markers.slice(-12).map(m => '- [' + fmtDuration(m.timestamp_ms || 0) + '] ' + (m.transcript_anchor || '用户手动重点')).join('\\n') || '（暂无重点标记）';\n  const recentTranscript = formatTranscriptLines(appState.segments.slice(-60));\n  const researchItems = appState.research.slice(-12).map(r => '- ' + (r.status || 'draft') + '：' + (r.text || '') + (r.evidence ? '（依据：' + r.evidence + '）' : '')).join('\\n') || '（暂无研究事项）';\n  const chatHistory = appState.agentMessages.slice(-12).map(m => m.role + '：' + m.content).join('\\n') || '（暂无对话）';\n  let sourceBlock = '';\n  if (sourceType === 'marker') {\n    const marker = appState.markers.find(m => m.id === sourceId);\n    if (marker) sourceBlock = formatTranscriptLines(getNearbyTranscript(marker.timestamp_ms || 0, 4));\n  } else if (sourceType === 'research') {\n    const r = appState.research.find(x => x.id === sourceId);\n    sourceBlock = r ? ((r.evidence ? '依据：' + r.evidence + '\\n' : '') + '事项：' + r.text) : '';\n  }\n  return [\n    '# 用户当前需求',\n    request || '请基于当前会议材料主动判断下一步该怎么处理。',\n    '',\n    '# 来源',\n    sourceType + (sourceId ? ' / ' + sourceId : ''),\n    sourceBlock ? '\\n# 来源附近上下文\\n' + sourceBlock : '',\n    '',\n    '# 当前录音笔记',\n    '- 标题：' + (session.title || '未命名会议'),\n    '- 状态：' + (session.status || 'active'),\n    '- 会议时长：' + fmtDuration(session.duration_ms || currentRecordMs()),\n    '',\n    '# 最近摘要',\n    summaries.length ? summaries.map((s, i) => (i + 1) + '. ' + s).join('\\n') : '（暂无摘要）',\n    '',\n    '# 用户重点标记',\n    markers,\n    '',\n    '# 已识别的 EchoAgent 研究事项',\n    researchItems,\n    '',\n    '# 最近逐字稿',\n    recentTranscript,\n    '',\n    '# EchoREC Agent 最近对话',\n    chatHistory,\n    '',\n    '# 输出要求',\n    '- 你是 EchoREC 自己的会议 Agent，不是单纯的任务派发按钮。',\n    '- 先理解用户意图：可能是问会议内容、要求整理、要求把重点标记变成行动、或要求调用 EchoAgent 做研究。',\n    '- 需要深入研究、查资料、跨应用执行时，直接给出你已调用/将调用 EchoAgent 的结论与进展，不要让用户自己选择工具。',\n    '- 回答中文，短而明确；需要行动时给出可执行结果或下一步。',\n  ].filter(Boolean).join('\\n');\n}\nfunction describeAgentEvent(event) {\n  return describeResearchEvent(event) || null;\n}\nfunction setAgentRunProgress(runId, phase, label, detail) {\n  const progress = { phase, label, detail: detail || '', updatedAt: nowMs() };\n  appState.agentProgress[runId] = progress;\n  const run = appState.agentRuns.find(r => r.id === runId);\n  if (run) { run.progress = progress; run.updated_at = nowMs(); }\n  dbUpdateAgentRun(runId, { progress_json: JSON.stringify(progress), updated_at: nowMs() }).catch(() => {});\n  renderTasks();\n}\nfunction latestRunFor(sourceType, sourceId) {\n  const runs = appState.agentRuns.filter(r => r.source_type === sourceType && r.source_id === sourceId);\n  return runs.length ? runs[runs.length - 1] : null;\n}\nasync function runEchoRecAgent(options) {\n  if (!appState.currentSessionId) { toast('先创建或选择一条录音笔记'); return; }\n  const text = String(options && options.text || '').trim();\n  const sourceType = options && options.sourceType || 'manual';\n  const sourceId = options && options.sourceId || uuid();\n  if (options && options.addUserMessage !== false) await addAgentMessage('user', text || '处理这个会议上下文', sourceType, sourceId);\n  const run = { id: uuid(), session_id: appState.currentSessionId, source_type: sourceType, source_id: sourceId, status: 'queued', progress: null, result: null, error: null, created_at: nowMs(), updated_at: nowMs() };\n  appState.agentRuns.push(run);\n  try { await dbInsertAgentRun(run); } catch {}\n  setAgentRunProgress(run.id, 'queued', '排队中', '等待 EchoAgent 接收任务');\n  if (sourceType === 'research') {\n    const r = appState.research.find(x => x.id === sourceId);\n    if (r) { r.status = 'dispatching'; await dbUpdateResearch(r.id, { status: 'dispatching' }); }\n  }\n  const systemContext = [\n    '你是 EchoREC Agent：会议录音、摘要、逐字稿、重点标记和 EchoAgent 执行之间的统一对话层。',\n    '你可以调用底层 EchoAgent 能力处理研究、整理、跨应用执行和后续任务。',\n    '不要把工具选择推给用户；你需要根据会议上下文和用户输入主动完成。',\n  ].join('\\n');\n  try {\n    const reply = await echobraid.ai.chat({\n      prompt: buildEchoRecAgentPrompt({ text, sourceType, sourceId }),\n      systemContext,\n      maxTokens: 2000,\n    }, (event) => {\n      const next = describeAgentEvent(event);\n      if (next) setAgentRunProgress(run.id, next.phase, next.label, next.detail);\n    });\n    const result = (reply && (reply.text || reply.content)) || '（无结果）';\n    run.status = 'done'; run.result = result; run.updated_at = nowMs();\n    setAgentRunProgress(run.id, 'done', '完成', 'EchoREC Agent 已生成结论');\n    await dbUpdateAgentRun(run.id, { status: 'done', result, updated_at: run.updated_at });\n    await addAgentMessage('assistant', result, sourceType, sourceId);\n    if (sourceType === 'research') {\n      const r = appState.research.find(x => x.id === sourceId);\n      if (r) { r.status = 'done'; r.result = result; await dbUpdateResearch(r.id, { status: 'done', result }); }\n    }\n  } catch (e) {\n    const error = e && e.message ? e.message : String(e);\n    run.status = 'failed'; run.error = error; run.updated_at = nowMs();\n    setAgentRunProgress(run.id, 'failed', '失败可重试', error);\n    await dbUpdateAgentRun(run.id, { status: 'failed', error, updated_at: run.updated_at });\n    if (sourceType === 'research') {\n      const r = appState.research.find(x => x.id === sourceId);\n      if (r) { r.status = 'draft'; await dbUpdateResearch(r.id, { status: 'draft' }); }\n    }\n    await addAgentMessage('system', 'EchoREC Agent 失败：' + error, sourceType, sourceId);\n    toast('EchoREC Agent 失败：' + error, 'error');\n  }\n}\nasync function sendAgentMessage() {\n  const input = document.getElementById('agent-input');\n  if (!input) return;\n  const text = input.value.trim();\n  if (!text) return;\n  input.value = '';\n  await runEchoRecAgent({ sourceType: 'manual', sourceId: uuid(), text });\n}\nasync function retryAgentRun(id) {\n  const run = appState.agentRuns.find(r => r.id === id);\n  if (!run) return;\n  const text = run.source_type === 'research'\n    ? ((appState.research.find(r => r.id === run.source_id) || {}).text || '继续处理这个研究事项')\n    : run.source_type === 'marker'\n      ? '处理这个重点标记，判断它对应的会议事项和后续行动'\n      : '请继续处理刚才的需求';\n  await runEchoRecAgent({ sourceType: run.source_type || 'manual', sourceId: run.source_id || uuid(), text });\n}\n\nasync function dispatchResearch(id) {\n  const r = appState.research.find(x => x.id === id);\n  if (!r || r.status === 'dispatching') return;\n  await runEchoRecAgent({ sourceType: 'research', sourceId: id, text: '请调用 EchoAgent 处理这个会议研究事项：' + (r.text || '') });\n}\n\n\nasync function deleteResearchItem(id) {\n  const r = appState.research.find(x => x.id === id);\n  if (!r) return;\n  const preview = (r.text || '').slice(0, 30) + ((r.text || '').length > 30 ? '…' : '');\n  if (!window.confirm('确定删除这个研究事项？\\n\\n' + preview)) return;\n  appState.research = appState.research.filter(x => x.id !== id);\n  try { await dbDeleteResearch(id); } catch {}\n  renderTasks();\n}\n\nasync function editResearchItem(id, newText) {\n  const r = appState.research.find(x => x.id === id);\n  if (!r) return;\n  const trimmed = (newText || '').trim();\n  if (!trimmed) return;\n  r.text = trimmed;\n  // Editing the text invalidates any prior result — reset status\n  r.status = 'draft';\n  r.result = null;\n  try { await dbUpdateResearch(id, { text: trimmed, status: 'draft', result: null }); } catch {}\n  renderTasks();\n}\n\n/* ═══ File upload ═══ */\nlet uploadInFlight = false;\nasync function handleFileUpload(file) {\n  if (!file) return;\n  // Concurrency guard: double-click / re-select would otherwise spawn parallel\n  // pipelines sharing appState.recording / wsConnected / currentSessionId and\n  // corrupt the state machine (double WS, interleaved DB writes).\n  if (uploadInFlight) { toast('已有上传任务在进行中'); return; }\n  if (appState.recording) { toast('录音中，先停止再上传'); return; }\n  uploadInFlight = true;\n  try {\n    await handleFileUploadImpl(file);\n  } catch (e) {\n    toast('上传失败：' + (e && e.message || e), 'error');\n    try { await stopRecording(); } catch {}\n  } finally {\n    uploadInFlight = false;\n  }\n}\nasync function handleFileUploadImpl(file) {\n  if (file.size > 50 * 1024 * 1024) {\n    toast('文件太大（>50MB）', 'error');\n    return;\n  }\n  await dbCreateSession('upload');\n  const buf = await file.arrayBuffer();\n  let audioBuffer;\n  try {\n    const Ctx = window.AudioContext || window.webkitAudioContext;\n    const tmp = new Ctx();\n    audioBuffer = await tmp.decodeAudioData(buf.slice(0));\n    await tmp.close();\n  } catch (e) {\n    toast('音频解码失败：' + (e.message || e), 'error');\n    return;\n  }\n  const off = new OfflineAudioContext(1, Math.ceil(audioBuffer.duration * SAMPLE_RATE), SAMPLE_RATE);\n  const src = off.createBufferSource();\n  src.buffer = audioBuffer;\n  src.connect(off.destination);\n  src.start();\n  const rendered = await off.startRendering();\n  const ch = rendered.getChannelData(0);\n  // xiaozhi wants raw Float32; resampled channel data is already Float32 in [-1,1].\n  // Clamp defensively in case decoder overshoots on int → float conversion.\n  const pcm = new Float32Array(ch.length);\n  for (let i = 0; i < ch.length; i++) {\n    pcm[i] = Math.max(-1, Math.min(1, ch[i]));\n  }\n  setStatus('uploading', '上传识别中（' + Math.round(rendered.duration) + 's）…');\n  appState.recordStartMs = nowMs();\n  appState.timerHandle = setInterval(tickTimer, 500);\n  appState.summaryTimerHandle = setInterval(maybeRunSummary, 5000);\n  appState.lastSummaryAt = nowMs();\n  appState.lastSummaryCharCount = 0;\n  appState.recording = true;\n  renderAudioFiles();\n  updateMicUI();\n  await openWs();\n  await beginAudioArchive('upload');\n  for (let i = 0; i < pcm.length; i += FRAME_SAMPLES) {\n    const chunk = pcm.slice(i, Math.min(i + FRAME_SAMPLES, pcm.length));\n    if (!appState.wsConnected) break;\n    await sendFrame(chunk);\n    // Pace at ~150ms per 200ms frame — xiaozhi processes in real time, flooding\n    // would just queue up upstream without helping.\n    await new Promise(r => setTimeout(r, 150));\n  }\n  // Finish imported audio as a completed note, including one persisted audio file.\n  await stopSession();\n}\n\n/* ═══ Render ═══ */\n\nfunction renderHome() {\n  const list = document.getElementById('home-session-list');\n  const count = document.getElementById('home-history-count');\n  const quota = document.getElementById('home-quota');\n  if (quota) quota.textContent = fmtMmSs(quotaRemainingSeconds() == null ? 60 * 60 : quotaRemainingSeconds());\n  if (count) count.textContent = appState.sessions.length ? appState.sessions.length + ' 条记录' : '暂无记录';\n  if (!list) return;\n  if (!appState.sessions.length) {\n    list.innerHTML = '<div class=\"home-empty\">还没有录音记录。点击上方“开始录音”，创建第一条会议笔记。</div>';\n    return;\n  }\n  list.innerHTML = appState.sessions.map(s => {\n    const duration = Number(s.duration_ms) ? fmtDuration(s.duration_ms) : '未计时';\n    const audio = Number(s.audio_count || 0) > 0 ? '录音文件 ' + Number(s.audio_count || 0) : '';\n    const meta = [fmtDate(s.started_at), duration, audio].filter(Boolean).map(x => '<span>' + escapeHtml(x) + '</span>').join('');\n    return '<button class=\"home-session-card\" data-id=\"' + escapeHtml(s.id) + '\">' +\n      '<span><div class=\"home-session-name\">' + escapeHtml(s.title || '未命名会话') + '</div><div class=\"home-session-meta\">' + meta + '</div></span>' +\n      '<span class=\"home-session-open\">打开</span>' +\n    '</button>';\n  }).join('');\n  list.querySelectorAll('.home-session-card').forEach(btn => {\n    btn.addEventListener('click', () => switchSession(btn.dataset.id));\n  });\n}\nfunction updateViewMode() {\n  document.body.classList.toggle('home-mode', !appState.currentSessionId);\n}\nfunction clearCurrentSessionState() {\n  revokeAudioUrls();\n  appState.currentSessionId = null;\n  appState.segments = []; appState.summaries = []; appState.actions = []; appState.questions = []; appState.research = [];\n  appState.markers = []; appState.agentMessages = []; appState.agentRuns = []; appState.agentProgress = {}; appState.audioFiles = [];\n  appState.audioArchive = null;\n}\nfunction renderSessions() {\n  const el = document.getElementById('session-list');\n  if (!appState.sessions.length) {\n    el.innerHTML = '<div class=\"empty\">暂无录音笔记</div>';\n    renderHome();\n    return;\n  }\n  el.innerHTML = appState.sessions.map(s => {\n    const active = s.id === appState.currentSessionId ? 'active' : '';\n    return '<div class=\"session-item ' + active + '\" data-id=\"' + escapeHtml(s.id) + '\">' +\n      '<div class=\"session-title-row\">' +\n        '<div class=\"session-title\">' + escapeHtml(s.title || '未命名会话') + '</div>' +\n        '<button class=\"session-delete\" data-action=\"delete-session\" data-id=\"' + escapeHtml(s.id) + '\" aria-label=\"删除录音笔记\">×</button>' +\n      '</div>' +\n      '<div class=\"session-meta\"><span>' + fmtDate(s.started_at) + '</span><span>' + fmtDuration(s.duration_ms) + '</span></div>' +\n      '</div>';\n  }).join('');\n  el.querySelectorAll('.session-item').forEach(node => {\n    node.addEventListener('click', () => switchSession(node.dataset.id));\n  });\n  el.querySelectorAll('[data-action=\"delete-session\"]').forEach(btn => {\n    btn.addEventListener('click', e => {\n      e.stopPropagation();\n      deleteSession(btn.dataset.id);\n    });\n  });\n  renderHome();\n}\n\n\nasync function deleteSession(id) {\n  if (!id) return;\n  if (appState.recording && id === appState.currentSessionId) {\n    toast('录音中，先结束当前笔记再删除');\n    return;\n  }\n  const target = appState.sessions.find(s => s.id === id);\n  if (!target) return;\n  if (!confirm('删除这条录音笔记？转写、摘要、任务和本地录音文件都会删除。')) return;\n  try {\n    const files = await echobraid.db.query('SELECT path FROM audio_files WHERE session_id=?', [id]) || [];\n    for (const f of files) {\n      if (!f || !f.path) continue;\n      try { await echobraid.invoke('fs.appRemove', { path: f.path }); } catch {}\n    }\n    await echobraid.db.exec('DELETE FROM audio_files WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM markers WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM agent_messages WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM agent_runs WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM research WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM actions WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM questions WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM summaries WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM segments WHERE session_id=?', [id]);\n    await echobraid.db.exec('DELETE FROM sessions WHERE id=?', [id]);\n    await dbLoadSessions();\n    if (id === appState.currentSessionId) {\n      clearCurrentSessionState();\n    }\n    renderSessions(); renderTranscript(); renderSummaries(); renderTasks(); renderAudioFiles();\n    updateMicUI();\n    toast('已删除录音笔记');\n  } catch (e) {\n    toast('删除失败：' + (e && e.message || e), 'error');\n  }\n}\n\nasync function switchSession(id) {\n  if (appState.recording) { toast('录音中无法切换'); return; }\n  appState.currentSessionId = id;\n  await dbLoadSegments(id);\n  await dbLoadSummaries(id);\n  await dbLoadActions(id);\n  await dbLoadQuestions(id);\n  await dbLoadResearch(id);\n  await dbLoadMarkers(id);\n  await dbLoadAgentMessages(id);\n  await dbLoadAgentRuns(id);\n  await dbLoadAudioFiles(id);\n  renderSessions(); renderTranscript(); renderSummaries(); renderTasks(); renderAudioFiles();\n  updateMicUI();\n}\n\n/* Stable per-speaker color palette index. xiaozhi labels are '说话人N' (N monotonic\n   within a WS connection); we hash the trailing digit to a 6-color cycle so the\n   same speaker looks the same throughout the meeting. Labels without a digit\n   (e.g. '未知' / unexpected shapes) return -1 → a neutral gray class, so they\n   don't collide with 说话人6/12/... on hue-5. */\nfunction speakerHue(label) {\n  if (!label) return -1;\n  const m = /(\\d+)/.exec(label);\n  if (!m) return -1;\n  const n = parseInt(m[1], 10);\n  if (!Number.isFinite(n) || n <= 0) return -1;\n  return ((n - 1) % 6 + 6) % 6;\n}\n\nfunction renderTranscript() {\n  const body = document.getElementById('transcript-body');\n  const hint = document.getElementById('transcript-hint');\n  if (!appState.segments.length) {\n    body.innerHTML = appState.markers.length\n      ? '<div class=\"empty\">已记录 ' + appState.markers.length + ' 个重点，等待逐字稿对齐</div>'\n      : '<div class=\"empty\">等待录音内容</div>';\n    hint.textContent = appState.markers.length ? appState.markers.length + ' 个重点' : '';\n    return;\n  }\n  // Only auto-scroll to bottom if the user is already near the bottom —\n  // don't yank them away when they're scrolled up reading earlier segments.\n  const nearBottom = (body.scrollHeight - body.clientHeight - body.scrollTop) < 40;\n  const html = appState.segments.map((s, idx) => {\n    const prev = idx > 0 ? appState.segments[idx - 1] : null;\n    const showSpeaker = !prev || prev.speaker !== s.speaker;\n    const hue = s.speaker ? speakerHue(s.speaker) : -1;\n    const hueClass = hue < 0 ? 'hue-x' : ('hue-' + hue);\n    const speakerLabel = s.speaker\n      ? '<span class=\"utterance-speaker ' + hueClass + '\">' + escapeHtml(s.speaker) + '</span>'\n      : '';\n    const header = showSpeaker\n      ? '<div class=\"utterance-head\">' + speakerLabel + '<span class=\"utterance-time\">' + fmtDuration(s.start_ms) + '</span></div>'\n      : '';\n    const markers = appState.markers.filter(m => {\n      const t = Number(m.timestamp_ms) || 0;\n      return t >= (Number(s.start_ms) || 0) - 800 && t <= (Number(s.end_ms) || 0) + 800;\n    });\n    const markerHtml = markers.length\n      ? '<div class=\"utterance-markers\">' + markers.map(m => '<span class=\"utterance-marker\">重点 ' + fmtDuration(m.timestamp_ms || 0) + '</span>').join('') + '</div>'\n      : '';\n    return '<div class=\"utterance' + (showSpeaker ? ' first-of-speaker' : '') + '\">' +\n      header + markerHtml +\n      '<div class=\"utterance-text\">' + escapeHtml(s.text || '') + '</div>' +\n      '</div>';\n  }).join('');\n  body.innerHTML = html;\n  if (nearBottom) body.scrollTop = body.scrollHeight;\n  const speakers = new Set(appState.segments.map(s => s.speaker).filter(Boolean));\n  hint.textContent = appState.segments.length + ' 句' + (speakers.size > 1 ? ' · ' + speakers.size + ' 位说话人' : '') + (appState.markers.length ? ' · ' + appState.markers.length + ' 个重点' : '');\n}\n\n\nfunction renderSummaryEntryText(e) {\n  // Accept either a bare string (legacy) or {text,...} (new)\n  return typeof e === 'string' ? escapeHtml(e) : escapeHtml(e?.text || '');\n}\nfunction renderActionEntry(a) {\n  if (typeof a === 'string') return '<li>' + escapeHtml(a) + '</li>';\n  const task = escapeHtml(a?.task || a?.text || '');\n  const chips = [];\n  if (a?.owner) chips.push('<span class=\"chip owner\">@' + escapeHtml(a.owner) + '</span>');\n  if (a?.due) chips.push('<span class=\"chip due\">⏰ ' + escapeHtml(a.due) + '</span>');\n  return '<li>' + task + (chips.length ? '<span class=\"action-meta\">' + chips.join('') + '</span>' : '') + '</li>';\n}\nfunction renderSummarySection(label, labelClass, items, isAction) {\n  if (!items || !items.length) return '';\n  const lis = isAction\n    ? items.map(renderActionEntry).join('')\n    : items.map(e => '<li>' + renderSummaryEntryText(e) + '</li>').join('');\n  return '<div class=\"summary-section\">' +\n    '<div class=\"summary-label ' + labelClass + '\">' + label + '</div>' +\n    '<ul class=\"summary-list\">' + lis + '</ul>' +\n    '</div>';\n}\nfunction renderSummaries() {\n  const body = document.getElementById('summary-body');\n  if (!appState.summaries.length) {\n    body.innerHTML = '<div class=\"empty\">录音结束后生成摘要</div>';\n    return;\n  }\n  const nearBottom = (body.scrollHeight - body.clientHeight - body.scrollTop) < 40;\n  // Only show summaries that have useful narrative text; empty chunks should\n  // not add visual noise to the AI summary panel.\n  const visibleSummaries = appState.summaries.filter(sm => String(sm.narrative || '').trim());\n  body.innerHTML = visibleSummaries.map(sm => {\n    return '<div class=\"summary-item\">' +\n      '<div class=\"summary-narrative\">' + escapeHtml(sm.narrative || '') + '</div>' +\n      '</div>';\n  }).join('');\n  if (nearBottom) body.scrollTop = body.scrollHeight;\n}\n\n/* Only surface tasks that are a good fit for EchoAgent to work on\n   (research / investigation / lookup). Decisions, human-owned todos and open\n   questions are described in the narrative per-chunk summary — they don't\n   need AI help, so we don't clutter this panel with them. */\n/* Track which items are currently in inline-edit mode so re-renders\n   triggered by other state changes don't drop the user's in-progress edit. */\nconst editingResearchIds = new Set();\n\nfunction renderTasks() {\n  const body = document.getElementById('tasks-body');\n  if (!body) return;\n  const messages = appState.agentMessages.slice().sort((a, b) => a.created_at - b.created_at);\n  const pendingResearch = appState.research.slice().filter(r => r.status !== 'done').sort((a, b) => a.created_at - b.created_at);\n  const recentMarkers = appState.markers.slice(-6).reverse();\n  const failedRuns = appState.agentRuns.filter(r => r.status === 'failed').slice(-3).reverse();\n  const activeRuns = appState.agentRuns.filter(r => r.status === 'queued' || r.status === 'dispatching').slice(-3);\n  const intro = messages.length\n    ? ''\n    : '<div class=\"agent-intro\">我是 EchoREC Agent。可以直接问我会议内容，也可以让我把摘要事项、你按空格标记的重点交给 EchoAgent 继续处理。</div>';\n  const messageHtml = '<div class=\"agent-messages\">' + (messages.length ? messages.map(m => {\n    const role = m.role === 'user' ? 'user' : m.role === 'system' ? 'system' : 'assistant';\n    const label = role === 'user' ? '你' : role === 'system' ? '系统' : 'EchoREC Agent';\n    const content = role === 'assistant' ? renderMarkdown(m.content || '') : escapeHtml(m.content || '');\n    return '<div class=\"agent-message ' + role + '\"><div class=\"agent-message-meta\">' + label + '</div><div>' + content + '</div></div>';\n  }).join('') : '') + '</div>';\n  const runHtml = activeRuns.map(r => {\n    const p = appState.agentProgress[r.id] || r.progress || { phase: 'queued', label: '排队中', detail: '' };\n    return '<div class=\"agent-run-status\"><span class=\"task-progress-dot\"></span><span>' + escapeHtml(p.label || '处理中') + '</span>' + (p.detail ? '<span class=\"task-progress-detail\">' + escapeHtml(p.detail) + '</span>' : '') + '</div>';\n  }).join('');\n  const researchHtml = pendingResearch.length ? '<div class=\"tasks-section-hd\">会议建议 <span class=\"count\">' + pendingResearch.length + '</span></div><div class=\"agent-suggestions\">' + pendingResearch.map(r => {\n    const run = latestRunFor('research', r.id);\n    const progress = run && (appState.agentProgress[run.id] || run.progress);\n    const progressHtml = progress ? '<div class=\"task-progress ' + escapeHtml(progress.phase || 'queued') + '\"><span class=\"task-progress-dot\"></span><span>' + escapeHtml(progress.label || '处理中') + '</span>' + (progress.detail ? '<span class=\"task-progress-detail\">' + escapeHtml(progress.detail) + '</span>' : '') + '</div>' : '';\n    const disabled = r.status === 'dispatching' ? 'disabled' : '';\n    const label = r.status === 'dispatching' ? (progress && progress.label || '处理中…') : '让 Agent 处理';\n    return '<div class=\"agent-suggestion\">' +\n      '<div class=\"agent-suggestion-title\">摘要识别出的研究事项</div>' +\n      '<div class=\"agent-suggestion-text\">' + escapeHtml(r.text || '') + '</div>' + progressHtml +\n      '<div class=\"agent-suggestion-tools\">' +\n        '<button class=\"dispatch-btn\" data-action=\"dispatch\" data-id=\"' + escapeHtml(r.id) + '\" ' + disabled + '>' + label + '</button>' +\n        '<button class=\"icon-btn\" data-action=\"edit\" data-id=\"' + escapeHtml(r.id) + '\">修改</button>' +\n        '<button class=\"icon-btn danger\" data-action=\"delete\" data-id=\"' + escapeHtml(r.id) + '\">删除</button>' +\n      '</div>' +\n    '</div>';\n  }).join('') + '</div>' : '';\n  const markerHtml = recentMarkers.length ? '<div class=\"tasks-section-hd\">重点标记 <span class=\"count\">' + appState.markers.length + '</span></div><div class=\"agent-suggestions\">' + recentMarkers.map(m => {\n    return '<div class=\"agent-suggestion\">' +\n      '<div class=\"agent-suggestion-title\">重点 ' + fmtDuration(m.timestamp_ms || 0) + '</div>' +\n      '<div class=\"agent-suggestion-text\">' + escapeHtml(m.transcript_anchor || '录音中的手动重点标记') + '</div>' +\n      '<div class=\"agent-suggestion-tools\"><button class=\"toggle-btn\" data-action=\"handle-marker\" data-id=\"' + escapeHtml(m.id) + '\">处理这个重点</button></div>' +\n    '</div>';\n  }).join('') + '</div>' : '';\n  const failedHtml = failedRuns.length ? '<div class=\"agent-suggestions\">' + failedRuns.map(r => {\n    return '<div class=\"agent-run-status failed\"><span>' + escapeHtml(r.error || '执行失败') + '</span><button class=\"toggle-btn\" data-action=\"retry-run\" data-id=\"' + escapeHtml(r.id) + '\">重试</button></div>';\n  }).join('') + '</div>' : '';\n  const composer = '<div class=\"agent-composer\">' +\n    '<textarea id=\"agent-input\" class=\"agent-input\" rows=\"2\" placeholder=\"问 EchoREC Agent，或说：把刚才标记的重点整理成待办\"></textarea>' +\n    '<div class=\"agent-composer-actions\"><span class=\"agent-hint\">录音中按空格打重点；Enter 发送，Shift+Enter 换行</span><button id=\"agent-send\" class=\"dispatch-btn\">发送</button></div>' +\n  '</div>';\n  body.innerHTML = intro + messageHtml + runHtml + researchHtml + markerHtml + failedHtml + composer;\n\n  body.querySelectorAll('[data-action=\"dispatch\"]').forEach(btn => {\n    if (btn.disabled) return;\n    btn.addEventListener('click', () => dispatchResearch(btn.dataset.id));\n  });\n  body.querySelectorAll('[data-action=\"handle-marker\"]').forEach(btn => {\n    btn.addEventListener('click', () => {\n      const m = appState.markers.find(x => x.id === btn.dataset.id);\n      if (!m) return;\n      runEchoRecAgent({ sourceType: 'marker', sourceId: m.id, text: '请处理这个重点标记，判断它对应的会议事项、风险和后续行动。' });\n    });\n  });\n  body.querySelectorAll('[data-action=\"retry-run\"]').forEach(btn => {\n    btn.addEventListener('click', () => retryAgentRun(btn.dataset.id));\n  });\n  body.querySelectorAll('[data-action=\"edit\"]').forEach(btn => {\n    btn.addEventListener('click', () => {\n      editingResearchIds.add(btn.dataset.id);\n      renderResearchEditor(btn.dataset.id);\n    });\n  });\n  body.querySelectorAll('[data-action=\"delete\"]').forEach(btn => {\n    btn.addEventListener('click', () => deleteResearchItem(btn.dataset.id));\n  });\n  const input = document.getElementById('agent-input');\n  const send = document.getElementById('agent-send');\n  if (send) send.addEventListener('click', sendAgentMessage);\n  if (input) input.addEventListener('keydown', (e) => {\n    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAgentMessage(); }\n  });\n  body.scrollTop = body.scrollHeight;\n}\nfunction renderResearchEditor(id) {\n  const body = document.getElementById('tasks-body');\n  const r = appState.research.find(x => x.id === id);\n  if (!body || !r) return;\n  body.innerHTML = '<div class=\"task-item editing\">' +\n    '<textarea class=\"task-edit-area\" data-id=\"' + escapeHtml(r.id) + '\">' + escapeHtml(r.text) + '</textarea>' +\n    '<div class=\"task-edit-actions\">' +\n      '<button class=\"toggle-btn\" data-action=\"cancel-edit\" data-id=\"' + escapeHtml(r.id) + '\">取消</button>' +\n      '<button class=\"dispatch-btn\" data-action=\"save-edit\" data-id=\"' + escapeHtml(r.id) + '\">保存</button>' +\n    '</div>' +\n  '</div>';\n  const ta = body.querySelector('textarea[data-id=\"' + id + '\"]');\n  if (ta) { ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length); }\n  body.querySelector('[data-action=\"cancel-edit\"]').addEventListener('click', () => { editingResearchIds.delete(id); renderTasks(); });\n  body.querySelector('[data-action=\"save-edit\"]').addEventListener('click', async () => {\n    const next = body.querySelector('textarea[data-id=\"' + id + '\"]');\n    editingResearchIds.delete(id);\n    await editResearchItem(id, next ? next.value : r.text);\n  });\n}\n\n\nfunction chipLabel(s) { return s === 'done' ? '已完成' : s === 'dispatching' ? '研究中' : '待派发'; }\n\nasync function toggleAction(id) {\n  const a = appState.actions.find(x => x.id === id);\n  if (!a) return;\n  a.done = !a.done;\n  await dbUpdateAction(id, { done: a.done ? 1 : 0 });\n  renderTasks();\n}\n\nasync function toggleQuestion(id) {\n  const q = appState.questions.find(x => x.id === id);\n  if (!q) return;\n  q.resolved = !q.resolved;\n  await dbUpdateQuestion(id, { resolved: q.resolved ? 1 : 0 });\n  renderTasks();\n}\n\nfunction setStatus(kind, txt) {\n  const dot = document.getElementById('status-dot');\n  const text = document.getElementById('status-text');\n  dot.className = 'dot ' + (kind === 'connected' || kind === 'uploading' ? 'connected' : kind === 'error' ? 'error' : kind === 'recording' ? 'recording' : '');\n  text.textContent = txt;\n}\nfunction tickTimer() {\n  if (!appState.recordStartMs) return;\n  document.getElementById('timer').textContent = fmtDuration(nowMs() - appState.recordStartMs);\n  renderQuotaIndicator();\n  if (appState.recording && quotaRemainingSeconds() === 0) {\n    toast('今日 ASR 用量已达 1 小时上限，自动停止录音', 'error');\n    pauseRecording();\n  }\n}\nfunction updateMicUI() {\n  const micBtn = document.getElementById('btn-mic');\n  const stopBtn = document.getElementById('btn-stop');\n  const uploadBtn = document.getElementById('btn-upload');\n  const hasSession = !!appState.currentSessionId;\n  const finalized = currentSessionFinalized();\n  updateViewMode();\n  renderHome();\n  document.body.classList.toggle('live-note', hasSession && !finalized);\n  document.body.classList.toggle('ended-note', finalized);\n  if (appState.recording) {\n    micBtn.classList.add('recording');\n    micBtn.setAttribute('aria-label', '暂停');\n    setStatus('recording', '正在记录');\n  } else {\n    micBtn.classList.remove('recording');\n    micBtn.setAttribute('aria-label', finalized ? '开始新录音' : hasSession ? '继续录音' : '开始录音');\n    if (!appState.wsConnected) {\n      setStatus(finalized ? 'ended' : hasSession ? 'paused' : 'idle', finalized ? '笔记已完成' : hasSession ? '已暂停' : '未开始');\n    }\n  }\n  // Stop button visible whenever there is an active session (recording or paused)\n  stopBtn.style.display = hasSession && !finalized ? 'flex' : 'none';\n  uploadBtn.disabled = appState.recording || (hasSession && !finalized);\n}\n\n/* ═══ Init ═══ */\nasync function init() {\n  renderQuotaIndicator();\n  try { await dbInit(); }\n  catch (e) { toast('数据库初始化失败：' + (e.message || e), 'error'); return; }\n  await dbLoadSessions();\n  clearCurrentSessionState();\n  renderSessions(); renderTranscript(); renderSummaries(); renderTasks(); renderAudioFiles(); renderHome();\n  // Surface correct state right after load — without this the status bar\n  // stayed at the HTML-seeded \"未开始\" even when a prior session with segments\n  // was restored, misleading users into thinking their just-spoken words\n  // weren't captured (the visible segments are historical).\n  updateMicUI();\n  document.getElementById('btn-mic').disabled = false;\n\n  document.getElementById('btn-mic').addEventListener('click', async () => {\n    if (appState.recording) await pauseRecording();\n    else await startRecording();\n  });\n  document.getElementById('btn-stop').addEventListener('click', async () => {\n    await stopSession();\n  });\n  document.addEventListener('keydown', (e) => {\n    if (e.code !== 'Space' || e.repeat || isTypingTarget(e.target)) return;\n    if (!appState.recording) return;\n    e.preventDefault();\n    addMarkerFromKeyboard();\n  });\n  async function createBlankSession() {\n    if (appState.recording) { toast('录音中，先点⏹停止当前会话'); return; }\n    await dbCreateSession('mic');\n    appState.segments = []; appState.summaries = []; appState.actions = []; appState.questions = []; appState.research = [];\n    appState.markers = []; appState.agentMessages = []; appState.agentRuns = []; appState.agentProgress = {};\n    appState.audioFiles = []; revokeAudioUrls();\n    appState.summaryRetryAfterMs = 0; appState.summaryInFlight = false;\n    renderSessions(); renderTranscript(); renderSummaries(); renderTasks(); renderAudioFiles(); renderHome();\n    updateMicUI();\n  }\n  document.getElementById('btn-new-session').addEventListener('click', createBlankSession);\n  document.getElementById('home-start-recording').addEventListener('click', async () => {\n    if (appState.recording) return;\n    await startRecording();\n  });\n  document.getElementById('home-upload-audio').addEventListener('click', () => {\n    if (appState.recording) return;\n    document.getElementById('file-input').click();\n  });\n  document.getElementById('btn-upload').addEventListener('click', () => {\n    if (appState.recording) return;\n    document.getElementById('file-input').click();\n  });\n  document.getElementById('file-input').addEventListener('change', (e) => {\n    const f = e.target.files && e.target.files[0];\n    if (f) handleFileUpload(f);\n    e.target.value = '';\n  });\n\n  window.addEventListener('echobraid:event', onWsEvent);\n  refreshQuotaFromServer();\n\n  // Unload cleanup: ensure we don't leak mic/AudioContext/WS if the iframe\n  // is torn down (app switched away, hot reloaded, closed).\n  let teardownDone = false;\n  const teardown = () => {\n    if (teardownDone) return;\n    teardownDone = true;\n    try { window.removeEventListener('echobraid:event', onWsEvent); } catch {}\n    try { clearInterval(appState.timerHandle); } catch {}\n    try { clearInterval(appState.summaryTimerHandle); } catch {}\n    appState.timerHandle = null; appState.summaryTimerHandle = null;\n    try { appState.workletNode && appState.workletNode.disconnect(); } catch {}\n    try { appState.audioCtx && appState.audioCtx.close && appState.audioCtx.close(); } catch {}\n    try { appState.mediaStream && appState.mediaStream.getTracks().forEach(t => t.stop()); } catch {}\n    try { clearWsReconnect(); } catch {}\n    try { echobraid.ws.close(WS_CHANNEL); } catch {}\n    try { echobraid.ws.close(WS_QUOTA_CHANNEL); } catch {}\n    try { revokeAudioUrls(); } catch {}\n    appState.workletNode = null; appState.audioCtx = null; appState.mediaStream = null;\n    appState.recording = false; appState.wsConnected = false;\n  };\n  window.addEventListener('pagehide', teardown);\n  window.addEventListener('beforeunload', teardown);\n\n  log('app', 'init ready (version: xiaozhi-v2-single-audio-note)');\n}\n\nif (document.readyState === 'loading') {\n  document.addEventListener('DOMContentLoaded', init);\n} else {\n  init();\n}\n\n})();\n</script>\n</body>\n</html>","prompt":{"seed":{"goal":"一个出厂内置的会议速记应用：实时录音流式转写（直连 xiaozhi 说话人识别 WS 服务）+ 服务端声纹聚类区分说话人 + 滚动窗口总结要点并识别研究任务，用户点派发后由 EchoAgent 执行研究并回填结果。"},"current":{"goal":"会议速记（Phase 2）：说话人识别 + 滚动总结 + 研究派发"}}}