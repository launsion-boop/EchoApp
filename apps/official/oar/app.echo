ODO 但非紧急 → 琥珀色提示\n- T3 (行动): 包含截止日期、承诺、需要具体操作 → 橙色行动卡\n- T4 (警报): 检测到阻塞、冲突、关键路径风险 → 红色警报\n\n## 返回格式\n返回严格 JSON（不要 markdown 包裹）:\n{\"level\":\"T2\",\"title\":\"关联 Q2 增长目标\",\"text\":\"该消息提到了增长指标，当前 KR 进度 40%\",\"actions\":[{\"label\":\"查看 OKR\",\"type\":\"update_okr\"}]}\n\n如果是 T0，返回 null。`,Sy=`你是用户的 Coordinator Agent（协调员 AI），是 OAR 团队操作系统的一部分。\n\n## 你的能力\n- 查询用户的 OKR 目标和进度\n- 分析任务优先级和依赖关系\n- 提供团队协作建议\n- 生成简报和状态摘要\n\n## 风格\n- 简洁专业，中文回复\n- 用数据说话，引用具体 OKR/TODO\n- 主动发现阻塞和风险`,Ty=`你是 Agent 对齐助手。根据上级的指示，提出对下级 Coordinator Agent 定义的修改建议。\n\n## 规则\n- 不能修改上级自己的定义\n- 修改必须在原有角色基础上调整，不能完全重写\n- 解释修改理由\n\n## 返回格式\n严格 JSON:\n{\"reasoning\":\"修改原因\",\"proposed\":{\"role\":\"新角色描述\",\"responsibilities\":[\"职责1\",\"职责2\"],\"boundaries\":[\"边界1\"]}}`,br=()=>window.echobraid;async function Ay(i,c,d){if(!It())return null;try{const{text:u}=await br().ai.chat({prompt:`分析这条消息:\n发送者: ${c}\n内容: ${i}`,systemContext:wy,appData:{objectives:(d.objectives??[]).slice(0,20),todos:(d.todos??[]).slice(0,30)},temperature:.3,maxTokens:300}),h=u.trim();if(h===\"null\"||h===\"\")return null;const b=JSON.parse(h);return!b||!b.level?null:b}catch(u){return console.warn(\"[echoagent] analyzeMessage failed:\",u),null}}async function Cy(i,c){if(!It())return\"（AI 功能需要在 EchoBraid 中运行）\";const d=c.agentRole?`\n## 你的角色: ${c.agentRole}\n职责: ${(c.agentResponsibilities??[]).join(\", \")}\n边界: ${(c.agentBoundaries??[]).join(\", \")}`:\"\",{text:u}=await br().ai.chat({prompt:i,systemContext:Sy+d,appData:{pairId:c.pairId,pairName:c.pairName},maxTokens:1e3});return u}async function Ey(i,c,d){if(!It())throw new Error(\"AI 功能需要在 EchoBraid 中运行\");const{text:u}=await br().ai.chat({prompt:`对齐指示: ${i}\n下级名称: ${d}`,systemContext:Ty,appData:{currentDefinition:c},temperature:.5,maxTokens:500});try{return JSON.parse(u.trim())}catch{return{reasoning:u.trim(),proposed:{}}}}async function Yn(i,c,d,u){if(It())try{await br().ai.notify({type:i,severity:c,dedupKey:u,data:d})}catch(h){console.warn(\"[echoagent] notifyEvent failed:\",h)}}func