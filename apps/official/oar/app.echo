",members:[\"boss\",\"wangwu\",\"lisi\"],unread:0,lastMessage:\"渲染层这周能出demo吗？\",lastMessageAt:\"15:00\",icon:\"📱\",description:\"ClawApp生态开发\"},{id:\"dm-boss-lisi\",name:\"老板\",type:\"dm\",members:[\"boss\",\"lisi\"],unread:1,lastMessage:\"ClawApp渲染层这周能出demo吗？\",lastMessageAt:\"15:00\"},{id:\"dm-lisi-zhangsan\",name:\"张三\",type:\"dm\",members:[\"lisi\",\"zhangsan\"],unread:0,lastMessage:\"散热方案确认没问题\",lastMessageAt:\"11:20\"},{id:\"pair-lisi\",name:\"我的Agent\",type:\"pair\",members:[\"lisi\",\"lisi-agent\"],unread:3,lastMessage:\"今日摘要已准备好\",lastMessageAt:\"08:00\",icon:\"🤖\"},{id:\"pair-boss\",name:\"我的Agent\",type:\"pair\",members:[\"boss\",\"boss-agent\"],unread:1,lastMessage:\"团队周报已生成\",lastMessageAt:\"08:00\",icon:\"🤖\"},{id:\"pair-wangwu\",name:\"我的Agent\",type:\"pair\",members:[\"wangwu\",\"wangwu-agent\"],unread:0,icon:\"🤖\"},{id:\"pair-xiaochen\",name:\"我的Agent\",type:\"pair\",members:[\"xiaochen\",\"xiaochen-agent\"],unread:0,icon:\"🤖\"}]}function ip(){return{\"project-hw\":[{id:\"m1\",channelId:\"project-hw\",senderId:\"zhangsan\",text:\"蓝牙HFP那个功耗问题解决了吗？我这边ID需要确认散热方案\",timestamp:\"10:32\"},{id:\"m2\",channelId:\"project-hw\",senderId:\"lisi-agent\",text:`李四目前在外面，我先回复：\n昨天测试数据显示待机功耗已降到12mA，详细报告在 wiki/bluetooth/power.md\n李四回来后会确认散热方案的影响`,timestamp:\"10:33\",isAgent:!0},{id:\"m3\",channelId:\"project-hw\",senderId:\"lisi\",text:\"回来了。散热没问题，12mA那版可以定，@张三 你按这个出ID\",timestamp:\"11:15\",agentSupplement:`✅ 已更新TODO: O1-R3 蓝牙功耗 → 已确认，状态改为【已完成】\n📌 已通知张三Agent关联ID出图任务`},{id:\"m4\",channelId:\"project-hw\",senderId:\"zhangsan\",text:\"收到，ID今天下午出初版\",timestamp:\"11:18\"},{id:\"m5\",channelId:\"project-hw\",senderId:\"xiaochen\",text:\"补充一下：12mA是在HFP+A2DP同时开的情况下测的，纯待机更低，大概8mA\",timestamp:\"11:30\"},{id:\"m6\",channelId:\"project-hw\",senderId:\"boss\",text:\"很好，蓝牙功耗这块进展不错。@李四 FCC认证的事情跟进到哪了？\",timestamp:\"14:20\"}],\"dm-boss-lisi\":[{id:\"dm1\",channelId:\"dm-boss-lisi\",senderId:\"boss\",text:\"ClawApp渲染层这周能出demo吗？\",timestamp:\"15:00\"},{id:\"dm2\",channelId:\"dm-boss-lisi\",senderId:\"lisi-agent\",text:`李四正在开会，我先同步进度：\n渲染层核心已完成80%，剩余主要是动画过渡部分，预计周四可出demo\n李四出来后会确认具体时间`,timestamp:\"15:01\",isAgent:!0},{id:\"dm3\",channelId:\"dm-boss-lisi\",senderId:\"lisi\",text:\"老板，周四下午可以demo，动画部分可能还是placeholder先顶着\",timestamp:\"16:20\",whisper:`💡 老板问的是O2-R1，当前进度68%\n建议提一下需要设计支援动画规范`}],\"team-all\":[{id:\"ta1\",channelId:\"team-all\",senderId:\"boss\",text:`各位，本周重点推进：\n1. 硬件V1量产冲刺\n2. ClawApp渲染层demo\n3. B端客户拜访安排\n\n请各自更新OAR进度`,timestamp:\"09:00\"},{id:\"ta2\",channelId:\"team-all\",senderId:\"boss-agent\",text:`📊 本周OAR进度汇总：\n• O1 硬件量产: 62% 🟢\n• O2 ClawApp: 42% 🟡\n• O3 B端签约: 15% 🟢\n\n详细报告见 OAR Dashboard`,timestamp:\"09:05\",isAgent:!0}],\"project-app\":[{id:\"pa1\",channelId:\"project-app\",senderId:\"wangwu\",text:\"渲染引擎的WebView方案测试结果出来了，性能比预期好，60fps稳定\",timestamp:\"11:00\"},{id:\"pa2\",channelId:\"project-app\",senderId:\"lisi\",text:\"那动画部分你打算用什么方案？\",timestamp:\"11:05\"},{id:\"pa3\",channelId:\"project-app\",senderId:\"wangwu\",text:\"考虑用 Lottie + 自定义过渡，下午出个方案\",timestamp:\"11:08\"}],\"pair-lisi\":[{id:\"pm1\",channelId:\"pair-lisi\",senderId:\"lisi-agent\",text:`☀️ 早上好！今日摘要：\n\n📬 3条群消息需要你回复（已整理）\n💬 老板在私聊问了demo进度（已代回）\n📊 O2-R1 进度更新到68%\n📰 情报: Flutter 3.29 breaking change，我已写入wiki，建议本周处理`,timestamp:\"08:00\",isAgent:!0},{id:\"pm2\",channelId:\"pair-lisi\",senderId:\"lisi\",text:\"那个Flutter的事严重吗\",timestamp:\"08:15\"},{id:\"pm3\",channelId:\"pair-lisi\",senderId:\"lisi-agent\",text:`影响中等，主要是Navigator 2.0的API变了，我们用了3处，改动量约2h\n要不要我现在创建TODO并排进本周？`,timestamp:\"08:16\",isAgent:!0},{id:\"pm4\",channelId:\"pair-lisi\",senderId:\"lisi\",text:\"排进去吧\",timestamp:\"08:18\"},{id:\"pm5\",channelId:\"pair-lisi\",senderId:\"lisi-agent\",text:\"✅ 已创建TODO，优先级中，排在周三。同时通知了老板Agent这个风险点。\",timestamp:\"08:18\",isAgent:!0}],\"dm-lisi-zhangsan\":[{id:\"dz1\",channelId:\"dm-lisi-zhangsan\",senderId:\"zhangsan\",text:\"散热方案我测了两版，铝合金的散热效果更好，但重量多了15g\",timestamp:\"10:50\"},{id:\"dz2\",channelId:\"dm-lisi-zhangsan\",senderId:\"lisi\",text:\"15g可以接受，散热优先。你按铝合金方案出图吧\",timestamp